---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'bg' } }
  ];
}

const { lang } = Astro.params;
const title = lang === 'en' ? 'News - amioprenova' : 'Новини - amioprenova';
---

<Layout title={title} lang={lang as 'en' | 'bg'}>
  <h1 class="text-4xl font-bold mb-4">
    {lang === 'en' ? 'News' : 'Новини'}
  </h1>
  <p class="text-gray-600">
    {lang === 'en' ? 'News page placeholder' : 'Заместител на страницата новини'}
  </p>
</Layout>
