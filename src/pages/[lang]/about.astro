---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'bg' } }
  ];
}

const { lang } = Astro.params;
const title = lang === 'en' ? 'About - amioprenova' : 'За мен - amioprenova';
---

<Layout title={title} lang={lang as 'en' | 'bg'}>
  <h1 class="text-4xl font-bold mb-4">
    {lang === 'en' ? 'About' : 'За мен'}
  </h1>
  <p class="text-gray-600">
    {lang === 'en' ? 'About page placeholder' : 'Заместител на страницата за мен'}
  </p>
</Layout>
