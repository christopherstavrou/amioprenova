---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import Badge from '../../../components/Badge.astro';
import SharePopover from '../../../components/SharePopover.astro';
import GalleryLightbox from '../../../components/GalleryLightbox.astro';
import type { GalleryItem } from '../../../lib/events';
import { siteConfig } from '../../../config/site';

export const getStaticPaths = (async () => {
  const allPosts = await getCollection('blog', ({ id }) => id.startsWith('en/'));
  return allPosts.map(post => ({
    params: { slug: post.slug.replace('en/', '') },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const canonicalURL = `${siteConfig.baseUrl}/en/news/${post.slug.replace('en/', '')}`;
const hasGallery = (post.data.gallery ?? []).length > 0;
---

<Layout
  title={`${post.data.title} - amioprenova`}
  description={post.data.description}
  lang="en"
>
  <article class="max-w-3xl mx-auto">
    {post.data.image && (
      <div class="mb-8 rounded-lg overflow-hidden">
        <img
          src={post.data.image}
          alt={post.data.title}
          class="w-full aspect-video object-cover"
          loading="eager"
        />
      </div>
    )}

    <header class="mb-8">
      <h1 class="font-serif text-4xl font-bold text-text-primary mb-4">{post.data.title}</h1>
      <div class="flex items-center gap-4 text-sm text-text-secondary">
        <time datetime={post.data.pubDate}>{formattedDate}</time>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex gap-2 flex-wrap">
            {post.data.tags.map(tag => (
              <Badge>{tag}</Badge>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="prose prose-lg max-w-none mb-8">
      <Content />
    </div>

    {hasGallery && (
      <section class="mb-10">
        <h2 class="font-serif text-2xl font-bold mb-4">Gallery</h2>
        <GalleryLightbox items={post.data.gallery as GalleryItem[]} />
      </section>
    )}

    <footer class="border-t border-border pt-8">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <a
          href="/en/news"
          class="inline-block text-sm text-accent-primary hover:text-accent-primary-hover hover:underline transition-colors"
        >
          ← Back to all posts
        </a>
        <SharePopover url={canonicalURL} title={post.data.title} />
      </div>
    </footer>
  </article>
</Layout>

<style>
  /* Prose styling for markdown content with theme colors */
  .prose {
    color: var(--color-text-primary);
  }

  .prose h2 {
    @apply font-serif text-2xl font-bold mt-8 mb-4 text-text-primary;
  }

  .prose h3 {
    @apply font-serif text-xl font-bold mt-6 mb-3 text-text-primary;
  }

  .prose h4 {
    @apply font-serif text-lg font-bold mt-4 mb-2 text-text-primary;
  }

  .prose p {
    @apply mb-4 text-text-primary leading-relaxed;
  }

  .prose a {
    @apply text-accent-primary hover:text-accent-primary-hover underline transition-colors;
  }

  .prose strong {
    @apply font-semibold text-text-primary;
  }

  .prose em {
    @apply italic;
  }

  .prose ul,
  .prose ol {
    @apply ml-6 mb-4 text-text-primary;
  }

  .prose ul {
    @apply list-disc;
  }

  .prose ol {
    @apply list-decimal;
  }

  .prose li {
    @apply mb-2;
  }

  .prose blockquote {
    @apply border-l-4 border-accent-primary pl-4 italic my-4 text-text-secondary;
  }

  .prose code {
    @apply bg-surface-muted px-1.5 py-0.5 rounded text-sm font-mono text-accent-primary;
  }

  .prose pre {
    @apply bg-surface-muted p-4 rounded my-4 overflow-x-auto;
  }

  .prose pre code {
    @apply bg-transparent p-0 text-text-primary;
  }

  .prose img {
    @apply rounded-lg my-6;
  }

  .prose hr {
    @apply border-border my-8;
  }

  .prose table {
    @apply w-full border-collapse my-6;
  }

  .prose th,
  .prose td {
    @apply border border-border px-4 py-2 text-left;
  }

  .prose th {
    @apply bg-surface-muted font-semibold text-text-primary;
  }

  .prose td {
    @apply text-text-primary;
  }
</style>
