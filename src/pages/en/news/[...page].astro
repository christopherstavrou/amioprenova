---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import Card from '../../../components/Card.astro';
import Badge from '../../../components/Badge.astro';
import SharePopover from '../../../components/SharePopover.astro';
import { siteConfig } from '../../../config/site';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog', ({ id }) => id.startsWith('en/'));
  const sortedPosts = allPosts.sort((a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  );

  // If no posts, create one empty page so /en/news always builds
  if (sortedPosts.length === 0) {
    return [{ params: { page: undefined }, props: { page: { data: [], currentPage: 1, lastPage: 1, url: { prev: null, next: null } } } }];
  }

  return paginate(sortedPosts, { pageSize: 6 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const posts = page.data;
---

<Layout
  title={page.currentPage === 1 ? "News - amioprenova" : `News - Page ${page.currentPage} - amioprenova`}
  description="Latest news, updates, and announcements from amioprenova. Stay informed about releases, shows, and projects."
  lang="en"
>
  <PageHeader title="News" class="nav:text-center" />

  <div class="max-w-4xl mx-auto">
    {posts.length > 0 && (
      <div class="flex justify-end mb-8">
        <div class="relative w-full md:w-64">
          <input
            type="search"
            id="search-input"
            placeholder="Search posts..."
            class="w-full px-4 py-2 bg-surface border border-border rounded-lg focus:outline-none focus:border-accent-primary text-text-primary placeholder:text-text-secondary transition-colors"
          />
          <div id="search-results" class="hidden absolute top-full mt-2 w-full bg-surface-elevated border border-border rounded-lg shadow-lg max-h-96 overflow-y-auto z-10"></div>
        </div>
      </div>
    )}

    {posts.length === 0 ? (
      <p class="text-text-secondary text-lg">No news posts yet. Check back soon!</p>
    ) : (
      <div class="space-y-3 mb-6">
        {posts.map(post => {
          const postSlug = post.slug.replace('en/', '');
          const postUrl = `/en/news/${postSlug}`;
          const shareUrl = `${siteConfig.baseUrl}${postUrl}`;
          const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric'
          });
          return (
            <Card hover={true} padding="none">
              <div class="flex flex-col sm:flex-row">
                {post.data.image && (
                  <a href={postUrl} class="overflow-hidden rounded-t-md sm:rounded-t-none sm:rounded-l-md sm:shrink-0 sm:w-44">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full aspect-[3/1] sm:aspect-auto sm:h-full object-cover hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </a>
                )}
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3 p-4 flex-1 min-w-0">
                  <div class="flex-grow min-w-0">
                    <a href={postUrl} class="group">
                      <h2 class="font-serif text-lg font-bold mb-1 leading-snug group-hover:text-accent-primary transition-colors">{post.data.title}</h2>
                    </a>
                    <p class="text-text-secondary text-sm mb-2">{formattedDate}</p>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex gap-1.5 flex-wrap mb-2">
                        {post.data.tags.map(tag => (
                          <Badge>{tag}</Badge>
                        ))}
                      </div>
                    )}
                    <p class="text-text-primary text-sm line-clamp-2">{post.data.description}</p>
                    <a href={postUrl} class="text-sm font-medium text-accent-primary hover:text-accent-primary-hover hover:underline transition-colors mt-2 inline-block">
                      Read more →
                    </a>
                  </div>
                  <div class="flex gap-2 shrink-0 flex-wrap items-start">
                    <SharePopover url={shareUrl} title={post.data.title} />
                  </div>
                </div>
              </div>
            </Card>
          );
        })}
      </div>
    )}

    {/* Pagination */}
    {(page.lastPage > 1) && (
      <nav class="flex justify-between items-center border-t border-border pt-8 mb-12">
        <div>
          {page.url.prev ? (
            <a
              href={page.url.prev}
              class="inline-block px-4 py-2 border border-border rounded hover:border-accent-primary hover:text-accent-primary transition-colors"
            >
              ← Previous
            </a>
          ) : (
            <span class="inline-block px-4 py-2 border border-border-light rounded text-text-secondary cursor-not-allowed opacity-50">
              ← Previous
            </span>
          )}
        </div>

        <span class="text-sm text-text-secondary">
          Page {page.currentPage} of {page.lastPage}
        </span>

        <div>
          {page.url.next ? (
            <a
              href={page.url.next}
              class="inline-block px-4 py-2 border border-border rounded hover:border-accent-primary hover:text-accent-primary transition-colors"
            >
              Next →
            </a>
          ) : (
            <span class="inline-block px-4 py-2 border border-border-light rounded text-text-secondary cursor-not-allowed opacity-50">
              Next →
            </span>
          )}
        </div>
      </nav>
    )}
  </div>

  <script>
    import { initListSearch } from '../../../scripts/list-search';
    initListSearch({ type: 'post', lang: 'en' });
  </script>
</Layout>
