---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import { siteConfig } from '../../config/site';
import releases from '../../data/releases.json';
import videos from '../../data/videos.json';
import { getNextEvents, formatShortDate } from '../../lib/events';

const featuredRelease = releases.find(r => r.featured) || releases[0];
const featuredVideo = videos.find(v => v.featured) || videos[0];
const upcomingShows = getNextEvents(3).map(event => ({
  ...event,
  formattedDate: formatShortDate(event.startDate, 'en-US'),
}));
---

<Layout
  title="Home - amioprenova"
  description="Jazz vocalist and composer Ami Oprenova. Discover soulful interpretations, upcoming shows, and timeless music."
  lang="en"
>
  <!-- Split Hero -->
  <section class="hero-split relative -mx-4 -mt-6 md:-mt-8 nav:-mt-10 mb-6 pb-0 flex flex-col md:flex-row min-h-[600px]">
    <!-- Photo column -->
    <div class="md:w-[45%] h-[50vh] md:h-auto relative flex-shrink-0">
      <img
        src="/images/hero-performance.jpg"
        alt="Ami Oprenova performing live"
        class="absolute inset-0 w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-transparent to-bg/20 hidden md:block" aria-hidden="true"></div>
    </div>

    <!-- Text column -->
    <div class="md:w-[55%] flex items-center bg-surface px-8 py-8 md:px-12 lg:px-16">
      <div class="max-w-lg">
        <p class="text-accent-secondary font-serif italic text-lg mb-3 tracking-wide">Jazz Vocalist &amp; Composer</p>
        <h1 class="hero-name font-serif text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Ami Oprenova
        </h1>
        <p class="text-text-secondary text-lg leading-relaxed mb-5">
          Mesmerising audiences around the world with extraordinary scat singing, pure style, and a
          musicianship that spans from classical violin to the jazz stage.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button variant="primary" href={siteConfig.bandcampUrl} target="_blank" rel="noopener noreferrer">
            Listen on Bandcamp
          </Button>
          <Button variant="primary" href="/en/video">
            Watch
          </Button>
        </div>
      </div>
    </div>
  </section>

  <div class="space-y-10">
    <!-- 3-column cards: Release / Video / Show -->
    <section class="py-0">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Latest Release -->
        <Card padding="none" hover class="flex flex-col overflow-hidden">
          <div class="aspect-square overflow-hidden">
            <img
              src={featuredRelease.coverImage}
              alt={featuredRelease.title}
              class="w-full h-full object-cover transition-transform duration-slow group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-6 flex flex-col flex-1">
            <p class="text-xs font-semibold uppercase tracking-widest text-accent-secondary mb-4">Latest Release</p>
            <h2 class="font-serif text-xl font-bold mb-1">{featuredRelease.title}</h2>
            <p class="text-text-secondary text-sm mb-3">{featuredRelease.year}</p>
            <p class="text-text-secondary text-sm mb-4 line-clamp-3">{featuredRelease.description}</p>
            <div class="mt-auto flex flex-wrap gap-2">
              {featuredRelease.bandcampUrl && (
                <Button variant="primary" href={featuredRelease.bandcampUrl} target="_blank" rel="noopener noreferrer">
                  Listen
                </Button>
              )}
              {featuredRelease.spotifyUrl && (
                <Button variant="secondary" href={featuredRelease.spotifyUrl} target="_blank" rel="noopener noreferrer">
                  Spotify
                </Button>
              )}
              {featuredRelease.appleMusicUrl && (
                <Button variant="secondary" href={featuredRelease.appleMusicUrl} target="_blank" rel="noopener noreferrer">
                  Apple Music
                </Button>
              )}
            </div>
          </div>
        </Card>

        <!-- Featured Video — plays inline on click -->
        <Card padding="none" hover={false} class="flex flex-col overflow-hidden">
          <div class="video-card" data-youtube-id={featuredVideo.youtubeId}>
            <button
              class="video-thumb w-full block relative group aspect-video"
              aria-label={`Play ${featuredVideo.title}`}
            >
              <img
                src={featuredVideo.thumbnail}
                alt={featuredVideo.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/50 transition-colors">
                <svg class="w-14 h-14 text-white drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </div>
            </button>
            <div class="video-player hidden aspect-video overflow-hidden bg-black"></div>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <p class="text-xs font-semibold uppercase tracking-widest text-accent-secondary mb-4">Featured Video</p>
            <h2 class="font-serif text-lg font-bold mb-3 line-clamp-2">{featuredVideo.title}</h2>
            {featuredVideo.description && (
              <p class="text-text-secondary text-sm mb-4 line-clamp-3 flex-1">{featuredVideo.description}</p>
            )}
            <div class="mt-auto">
              <Button variant="primary" href="/en/video">
                Watch More
              </Button>
            </div>
          </div>
        </Card>

        <!-- Shows -->
        <Card padding="none" hover class="flex flex-col overflow-hidden">
          <div class="p-6 flex flex-col flex-1">
            <p class="text-xs font-semibold uppercase tracking-widest text-accent-secondary mb-4">Upcoming Shows</p>
            <h2 class="font-serif text-xl font-bold mb-4">Live Performances</h2>
            {upcomingShows.length > 0 ? (
              <ul class="flex-1 divide-y divide-border mb-6">
                {upcomingShows.map(event => (
                  <li class="py-3">
                    <a href={`/en/shows/${event.slug}`} class="block group">
                      <p class="text-xs text-text-secondary mb-0.5">{event.formattedDate}</p>
                      <p class="text-sm font-medium group-hover:text-accent-primary transition-colors">{event.title}</p>
                      <p class="text-xs text-text-secondary">{event.venue}, {event.city}</p>
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-text-secondary text-sm mb-6 flex-1">
                Catch Ami Oprenova live — jazz concerts, intimate sessions, and festival stages across Europe.
              </p>
            )}
            <div class="mt-auto">
              <Button variant="primary" href="/en/shows">
                View Shows
              </Button>
            </div>
          </div>
        </Card>

      </div>
    </section>

    <!-- Stay Connected -->
    <section id="newsletter" class="py-0">
      <div class="bg-surface rounded-md p-6 md:p-8 shadow-md border border-border">
        <div class="max-w-2xl mx-auto text-center">
          <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">Stay Connected</h2>
          <p class="text-lg mb-8 text-text-secondary">Get the latest news, show announcements, and exclusive content delivered to your inbox.</p>

          <!-- Newsletter Signup Form -->
          <form class="mb-5" action={siteConfig.mailchimpSignupUrl} method="post" target="_blank">
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <label for="newsletter-email" class="sr-only">Email address</label>
              <input
                type="email"
                id="newsletter-email"
                name="EMAIL"
                placeholder="Your email address"
                required
                class="px-4 py-3 rounded-md flex-grow max-w-md bg-surface text-text-primary border border-border focus:border-accent-primary focus:ring-2 focus:ring-accent-primary focus:ring-opacity-20"
              />
              <Button variant="primary" type="submit">
                Subscribe
              </Button>
            </div>
          </form>

          <!-- Social Links -->
          <div class="flex justify-center gap-6 mb-6">
            {siteConfig.instagramUrl && (
              <a href={siteConfig.instagramUrl} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-accent-secondary transition-colors" aria-label="Instagram">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            )}
            {siteConfig.facebookUrl && (
              <a href={siteConfig.facebookUrl} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-accent-secondary transition-colors" aria-label="Facebook">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            )}
            {siteConfig.youtubeUrl && (
              <a href={siteConfig.youtubeUrl} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-accent-secondary transition-colors" aria-label="YouTube">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            )}
          </div>

          <a href="/en/links" class="inline-block text-accent-secondary hover:text-accent-primary font-semibold">
            All Links →
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  import '../../scripts/inline-video';
</script>
