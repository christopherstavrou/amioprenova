---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Card from '../../components/Card.astro';
import Button from '../../components/Button.astro';
import { siteConfig } from '../../config/site';

// Booking mailto template
const bookingSubject = encodeURIComponent('Booking Inquiry');
const bookingBody = encodeURIComponent(`Hello,

I would like to inquire about booking you for a performance.

Details:
- Name/Organization:
- Venue:
- City, Country:
- Preferred Date(s):
- Budget:
- Set Length:
- Technical Requirements:
- Additional Information:

Links:
- Website:
- Social Media:

Thank you!`);

const bookingMailto = `mailto:${siteConfig.bookingEmail}?subject=${bookingSubject}&body=${bookingBody}`;

// Press mailto template
const pressSubject = encodeURIComponent('Press Inquiry');
const pressBody = encodeURIComponent(`Hello,

I am reaching out regarding a press inquiry.

Details:
- Outlet/Publication:
- Deadline:
- What's Needed (interview, photos, bio, etc.):
- Contact Information:
- Additional Information:

Thank you!`);

const pressMailto = `mailto:${siteConfig.pressEmail}?subject=${pressSubject}&body=${pressBody}`;
---

<Layout
  title="Contact - amioprenova"
  description="Get in touch with amioprenova for booking inquiries, press requests, and general questions. Contact via email."
  lang="en"
>
  <PageHeader title="Contact" />

  <div class="max-w-2xl mx-auto">
    <p class="text-lg text-text-secondary mb-6">
      Get in touch for bookings, press inquiries, or general questions.
    </p>

    <div class="grid gap-6 sm:grid-cols-2 mb-6">
      <Card hover={true} class="text-center">
        <h2 class="font-serif text-2xl font-bold mb-2">Booking</h2>
        <p class="text-sm text-text-secondary mb-6">
          Inquire about performances, concerts, and appearances
        </p>
        <Button variant="primary" href={bookingMailto} class="w-full">
          Send Booking Inquiry
        </Button>
      </Card>

      <Card hover={true} class="text-center">
        <h2 class="font-serif text-2xl font-bold mb-2">Press</h2>
        <p class="text-sm text-text-secondary mb-6">
          Media inquiries, interviews, and press materials
        </p>
        <Button variant="primary" href={pressMailto} class="w-full">
          Send Press Inquiry
        </Button>
      </Card>
    </div>

    <Card class="bg-surface-muted">
      <p class="text-sm text-text-secondary text-center">
        Please allow 2-3 business days for a response. For urgent matters, please indicate so in your message.
      </p>
    </Card>
  </div>
</Layout>
