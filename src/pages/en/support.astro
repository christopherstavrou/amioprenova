---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import { siteConfig } from '../../config/site';

const hasMusic = siteConfig.bandcampUrl;
const hasTickets = siteConfig.ticketsPlatformUrl;
const hasDonation = siteConfig.donationUrl;
const hasAffiliates = siteConfig.affiliateLinks.some(link => link.url);
---

<Layout
  title="Support / Buy - amioprenova"
  description="Support amioprenova's music. Buy albums on Bandcamp, get tickets, make a donation, and discover recommended gear."
  lang="en"
>
  <PageHeader
    title="Support / Buy"
    description="Support my music and get access to exclusive content, merch, and more."
  />

  <div class="max-w-4xl mx-auto">
    <div class="space-y-12">
      {hasMusic && (
        <section>
          <h2 class="font-serif text-2xl font-bold text-text-primary mb-4">Buy Music & Merch</h2>
          <p class="text-text-secondary mb-6">
            Get albums, digital downloads, and exclusive merchandise on Bandcamp.
          </p>
          <Button
            variant="primary"
            href={siteConfig.bandcampUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Visit Bandcamp
          </Button>
        </section>
      )}

      {hasTickets && (
        <section>
          <h2 class="font-serif text-2xl font-bold text-text-primary mb-4">Get Tickets</h2>
          <p class="text-text-secondary mb-6">
            Find and purchase tickets for upcoming shows and events.
          </p>
          <Button
            variant="primary"
            href={siteConfig.ticketsPlatformUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            View Tickets
          </Button>
        </section>
      )}

      {hasDonation && (
        <section>
          <h2 class="font-serif text-2xl font-bold text-text-primary mb-4">Support My Work</h2>
          <p class="text-text-secondary mb-6">
            Help support my music and creative projects. Every contribution helps me continue creating.
          </p>
          <Button
            variant="primary"
            href={siteConfig.donationUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Make a Donation
          </Button>
        </section>
      )}

      {hasAffiliates && (
        <section>
          <h2 class="font-serif text-2xl font-bold text-text-primary mb-4">Recommended</h2>
          <p class="text-text-secondary mb-6">
            Tools, gear, and services I use and recommend.
          </p>
          <div class="grid gap-4 sm:grid-cols-2">
            {siteConfig.affiliateLinks.filter(link => link.url).map(link => (
              <Card hover={true}>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block"
                >
                  <h3 class="font-bold text-text-primary mb-1">{link.label}</h3>
                  {link.note && <p class="text-sm text-text-secondary">{link.note}</p>}
                </a>
              </Card>
            ))}
          </div>
        </section>
      )}

      {!hasMusic && !hasTickets && !hasDonation && !hasAffiliates && (
        <div class="text-center py-12">
          <p class="text-text-secondary text-lg">
            Support options coming soon. Check back later or follow on social media for updates!
          </p>
        </div>
      )}
    </div>
  </div>
</Layout>
