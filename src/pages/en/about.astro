---
import Layout from '../../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import PageHeader from '../../components/PageHeader.astro';

const about = await getEntry('pages', 'en/about');
const { Content } = await about.render();
---

<Layout
  title={`${about.data.title} - amioprenova`}
  description={about.data.description}
  lang="en"
>
  <div class="max-w-4xl mx-auto">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <div class="md:col-span-1">
        <img
          src={about.data.image || 'https://placehold.co/800x800/8B1C3B/FFFFFF?text=Portrait'}
          alt="Ami Oprenova"
          class="w-full rounded-lg shadow-lg"
        />
      </div>
      <div class="md:col-span-2">
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-text-primary mb-6">
          {about.data.title}
        </h1>
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>
      </div>
    </div>
  </div>
</Layout>
