---
import Layout from '../../layouts/Layout.astro';
import { getUpcomingEvents, formatEventDate } from '../../lib/events';

const upcomingEvents = getUpcomingEvents();
---

<Layout
  title="Shows - amioprenova"
  description="Find upcoming concerts and live performances by amioprenova. Get tickets and view show dates, venues, and locations."
  lang="en"
>
  <h1 class="text-4xl font-bold mb-8">Upcoming Shows</h1>

  {upcomingEvents.length === 0 ? (
    <p class="text-gray-600 text-lg">
      No upcoming shows at the moment. Check back soon or follow on social media for announcements!
    </p>
  ) : (
    <div class="space-y-6">
      {upcomingEvents.map(event => (
        <div class="border border-gray-200 rounded-lg p-6 hover:border-gray-300 transition-colors">
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
            <div class="flex-grow">
              <h2 class="text-2xl font-bold mb-2">{event.title}</h2>
              <p class="text-gray-600 mb-1">
                <span class="font-medium">{formatEventDate(event.startDate, 'en')}</span>
              </p>
              <p class="text-gray-600">
                {event.venue} · {event.city}, {event.country}
              </p>
            </div>
            <div class="flex gap-3">
              {event.ticketUrl && (
                <a
                  href={event.ticketUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block px-4 py-2 bg-gray-900 text-white text-sm rounded hover:bg-gray-700 transition-colors"
                >
                  Tickets
                </a>
              )}
              {event.mapUrl && (
                <a
                  href={event.mapUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block px-4 py-2 border border-gray-300 text-gray-900 text-sm rounded hover:border-gray-400 transition-colors"
                >
                  Map
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  )}
</Layout>
