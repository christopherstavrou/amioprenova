---
// Temporary landing page for production launch.
// Replace this file with a redirect to /en once the full site is ready:
//   return Astro.redirect('/en', 302);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Ami Oprenova — Jazz Vocalist</title>
    <meta name="description" content="Ami Oprenova is a jazz vocalist performing soulful interpretations of timeless classics. Follow her music on Bandcamp and Facebook." />
    <link rel="canonical" href="https://amioprenova.com/" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://amioprenova.com/" />
    <meta property="og:title" content="Ami Oprenova — Jazz Vocalist" />
    <meta property="og:description" content="Jazz vocalist performing soulful interpretations of timeless classics." />
    <meta property="og:site_name" content="Ami Oprenova" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Ami Oprenova — Jazz Vocalist" />
    <meta name="twitter:description" content="Jazz vocalist performing soulful interpretations of timeless classics." />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --burgundy: #8B1C3B;
        --burgundy-dark: #6B1530;
        --gold: #CDA34A;
        --cream: #F7F4F0;
        --near-black: #1A1816;
        --text-muted: #9A9A9A;
        --border: rgba(255, 255, 255, 0.12);
      }

      html {
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
      }

      body {
        min-height: 100dvh;
        background-color: var(--near-black);
        color: var(--cream);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem;
        line-height: 1.6;

        /* Subtle radial gradient for atmosphere */
        background-image:
          radial-gradient(ellipse 80% 60% at 50% 0%, rgba(139, 28, 59, 0.18) 0%, transparent 70%),
          radial-gradient(ellipse 60% 40% at 50% 100%, rgba(205, 163, 74, 0.07) 0%, transparent 70%);
      }

      main {
        width: 100%;
        max-width: 560px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
      }

      /* Decorative rule */
      .rule {
        width: 40px;
        height: 1px;
        background: var(--gold);
        margin: 0 auto;
        opacity: 0.7;
      }

      /* Name */
      .artist-name {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(2.5rem, 8vw, 4rem);
        font-weight: 700;
        letter-spacing: -0.01em;
        line-height: 1.1;
        color: #fff;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
      }

      /* Tagline */
      .tagline {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(0.9rem, 2.5vw, 1.05rem);
        font-weight: 400;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1.5rem;
      }

      .rule-bottom {
        width: 40px;
        height: 1px;
        background: var(--gold);
        margin: 0 auto;
        opacity: 0.4;
      }

      /* Bio */
      .bio {
        font-size: 1rem;
        color: rgba(247, 244, 240, 0.65);
        max-width: 420px;
        margin-top: 2rem;
        margin-bottom: 2.5rem;
        line-height: 1.75;
      }

      /* Links section */
      .links {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        width: 100%;
        max-width: 320px;
        margin-bottom: 3rem;
      }

      .link-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.625rem;
        padding: 0.875rem 1.5rem;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.9375rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
        border: 1px solid transparent;
      }

      .link-btn:hover {
        transform: translateY(-1px);
      }

      .link-btn:active {
        transform: translateY(0);
      }

      .link-btn--primary {
        background-color: var(--burgundy);
        color: #fff;
        border-color: var(--burgundy);
      }

      .link-btn--primary:hover {
        background-color: var(--burgundy-dark);
        box-shadow: 0 4px 16px rgba(139, 28, 59, 0.4);
      }

      .link-btn--outline {
        background-color: transparent;
        color: var(--cream);
        border-color: rgba(247, 244, 240, 0.2);
      }

      .link-btn--outline:hover {
        background-color: rgba(247, 244, 240, 0.07);
        border-color: rgba(247, 244, 240, 0.4);
      }

      /* Icon inside button */
      .btn-icon {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
        opacity: 0.9;
      }

      /* Footer */
      footer {
        margin-top: auto;
        padding-top: 1.5rem;
        font-size: 0.8125rem;
        color: rgba(247, 244, 240, 0.3);
        letter-spacing: 0.04em;
      }

      /* Screenreader text */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap;
        border-width: 0;
      }

      /* Subtle entrance animation */
      @media (prefers-reduced-motion: no-preference) {
        main {
          animation: fadeUp 0.7s ease both;
        }
        @keyframes fadeUp {
          from { opacity: 0; transform: translateY(16px); }
          to   { opacity: 1; transform: translateY(0); }
        }
      }
    </style>
  </head>

  <body>
    <main>
      <div class="rule" aria-hidden="true"></div>

      <h1 class="artist-name">Ami Oprenova</h1>
      <p class="tagline">Jazz Vocalist</p>

      <div class="rule-bottom" aria-hidden="true"></div>

      <p class="bio">
        Soulful interpretations of timeless jazz standards and original music.
        Based in Europe, performing internationally.
      </p>

      <nav class="links" aria-label="Follow Ami Oprenova">
        <!-- Bandcamp — verified -->
        <a
          href="https://amioprenova.bandcamp.com"
          target="_blank"
          rel="noopener noreferrer"
          class="link-btn link-btn--primary"
        >
          <!-- Bandcamp logo -->
          <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M0 8v8h8.75l6-8H24V8H0z"/>
          </svg>
          Listen on Bandcamp
        </a>

        <!-- Instagram — verified (@vocalistami) -->
        <a
          href="https://www.instagram.com/vocalistami/"
          target="_blank"
          rel="noopener noreferrer"
          class="link-btn link-btn--outline"
        >
          <!-- Instagram logo -->
          <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd"/>
          </svg>
          Follow on Instagram
        </a>

        <!-- Facebook — verified -->
        <a
          href="https://www.facebook.com/amioprenovamusic/"
          target="_blank"
          rel="noopener noreferrer"
          class="link-btn link-btn--outline"
        >
          <!-- Facebook logo -->
          <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/>
          </svg>
          Follow on Facebook
        </a>
      </nav>
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Ami Oprenova. All rights reserved.</p>
    </footer>
  </body>
</html>
