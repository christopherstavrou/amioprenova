---
// Temporary landing page for soft production launch
// Replace this file with `return Astro.redirect('/en', 302);` when the full site is ready
import '../styles/global.css';
import { siteConfig } from '../config/site';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-performance.jpg';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ami Oprenova — Jazz Vocalist &amp; Composer</title>
    <meta name="description" content="World class Bulgarian-British jazz vocalist and composer. Ami Oprenova mesmerises audiences around the world with her energy, pure style, and extraordinary scat singing." />
    <link rel="canonical" href="https://amioprenova.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://amioprenova.com/" />
    <meta property="og:title" content="Ami Oprenova — Jazz Vocalist &amp; Composer" />
    <meta property="og:description" content="World class Bulgarian-British jazz vocalist and composer. Mesmerising audiences around the world with extraordinary scat singing and pure style." />
    <meta property="og:site_name" content="amioprenova" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Ami Oprenova — Jazz Vocalist &amp; Composer" />
    <meta name="twitter:description" content="World class Bulgarian-British jazz vocalist and composer. Mesmerising audiences around the world with extraordinary scat singing and pure style." />
  </head>
  <body>
    <main>
      <div class="hero">
        <Image
          src={heroImage}
          alt="Ami Oprenova performing live"
          class="hero__photo"
          width={1920}
          loading="eager"
        />
        <div class="hero__overlay" aria-hidden="true"></div>
        <div class="hero__content">
          <div class="ornament" aria-hidden="true">♩ ♪ ♫</div>

          <h1>Ami Oprenova</h1>
          <p class="tagline">World class Bulgarian-British jazz vocalist and composer</p>

          <blockquote class="quote">
            "Improvising is my way of expressing myself. The only time I feel truly alive and able to breathe in all that life has to offer."
          </blockquote>

          <p class="bio">
            For Ami Oprenova scatting isn't just a generic technique but a way of life. By opening
            herself to the unknown and taking a journey of incredible musicianship, Ami has been
            mesmerising audiences around the world with her energy and pure style. From a childhood
            of violin virtuoso, composing and conducting, to becoming an exceptional jazz performer
            and leader — Ami Oprenova has remarkable achievements behind her.
          </p>

          <p class="press-quote">
            "Oprenova's rousing scat singing is full of excellent technical mastery with incredible falsetto…"
            <cite>— Italia in Jazz ★★★★★</cite>
          </p>

          <nav class="links" aria-label="Social links">
            <a
              href={siteConfig.bandcampUrl}
              class="link link--primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M0 8v8h8.75l6-8H24V8H0z" />
              </svg>
              Listen on Bandcamp
            </a>

            <a
              href={siteConfig.instagramUrl}
              class="link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
              </svg>
              @amioprenovamusic
            </a>

            <a
              href={siteConfig.facebookUrl}
              class="link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
              </svg>
              Facebook
            </a>
          </nav>

          <footer>
            <p>&copy; {new Date().getFullYear()} Ami Oprenova</p>
          </footer>
        </div>
      </div>
    </main>

    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html, body {
        height: 100%;
      }

      body {
        background-color: var(--color-bg);
        color: var(--color-text-primary);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        min-height: 100vh;
      }

      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .hero__photo {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
      }

      .hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to bottom,
          var(--color-hero-scrim-start) 0%,
          var(--color-hero-scrim-mid) 60%,
          var(--color-hero-scrim-end) 100%
        );
      }

      .hero__content {
        position: relative;
        z-index: 1;
        max-width: 640px;
        width: 100%;
        text-align: center;
        padding: 2rem 1.5rem;
        animation: fadeIn 0.9s ease both;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .ornament {
        font-size: 1.25rem;
        color: var(--color-accent-gold);
        letter-spacing: 0.4em;
        margin-bottom: 2rem;
        opacity: 0.6;
      }

      h1 {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(2.5rem, 8vw, 4rem);
        font-weight: 700;
        color: var(--color-accent-gold);
        line-height: 1.1;
        letter-spacing: -0.01em;
        margin-bottom: 0.5rem;
      }

      .tagline {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(0.875rem, 2.5vw, 1.0625rem);
        color: var(--color-text-secondary);
        letter-spacing: 0.05em;
        margin-bottom: 2rem;
      }

      .quote {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(1rem, 2.5vw, 1.125rem);
        font-style: italic;
        color: var(--color-accent-gold);
        line-height: 1.6;
        margin-bottom: 1.5rem;
        padding: 0 0.5rem;
        border: none;
      }

      .bio {
        font-size: 0.9375rem;
        color: var(--color-text-secondary);
        line-height: 1.75;
        margin-bottom: 1.5rem;
        padding: 0 0.5rem;
        text-align: left;
      }

      .press-quote {
        font-size: 0.875rem;
        color: var(--color-text-secondary);
        font-style: italic;
        line-height: 1.6;
        margin-bottom: 3rem;
        padding: 0 0.5rem;
        opacity: 0.7;
      }

      .press-quote cite {
        display: block;
        font-style: normal;
        margin-top: 0.375rem;
        opacity: 0.8;
      }

      .links {
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        margin-bottom: 3rem;
      }

      .link {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.625rem;
        padding: 0.875rem 1.5rem;
        border-radius: 6px;
        font-size: 0.9375rem;
        font-weight: 500;
        text-decoration: none;
        transition: opacity var(--transition-fast), transform var(--transition-fast);
        border: 1px solid var(--color-border);
        color: var(--color-text-primary);
        background-color: var(--color-surface);
      }

      .link--primary {
        background-color: var(--color-accent-primary);
        border-color: var(--color-accent-primary);
        color: var(--color-text-inverse);
      }

      .link:hover {
        opacity: 0.85;
        transform: translateY(-1px);
      }

      .icon {
        width: 1.125rem;
        height: 1.125rem;
        flex-shrink: 0;
      }

      footer {
        font-size: 0.8125rem;
        color: var(--color-text-secondary);
        opacity: 0.5;
      }
    </style>
  </body>
</html>
