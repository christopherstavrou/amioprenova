---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import { siteConfig } from '../../config/site';

const hasMusic = siteConfig.bandcampUrl;
const hasTickets = siteConfig.ticketsPlatformUrl;
const hasDonation = siteConfig.donationUrl;
const hasAffiliates = siteConfig.affiliateLinks.some(link => link.url);
---

<Layout
  title="Подкрепи / Купи - amioprenova"
  description="Подкрепете музиката на amioprenova. Купете албуми в Bandcamp, вземете билети, направете дарение и открийте препоръчано оборудване."
  lang="bg"
>
  <PageHeader
    title="Подкрепи / Купи"
    subtitle="Подкрепете музиката ми и получете достъп до ексклузивно съдържание, стоки и още."
  />

  <div class="max-w-4xl mx-auto">
    <div class="space-y-12">
      {hasMusic && (
        <section>
          <h2 class="font-serif text-2xl font-bold text-text-primary mb-4">Купи музика и стоки</h2>
          <p class="text-text-secondary mb-6">
            Вземете албуми, дигитални изтегляния и ексклузивни стоки в Bandcamp.
          </p>
          <Button
            variant="primary"
            href={siteConfig.bandcampUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Посети Bandcamp
          </Button>
        </section>
      )}

      {hasTickets && (
        <section>
          <h2 class="font-serif text-2xl font-bold text-text-primary mb-4">Вземи билети</h2>
          <p class="text-text-secondary mb-6">
            Намерете и закупете билети за предстоящи концерти и събития.
          </p>
          <Button
            variant="primary"
            href={siteConfig.ticketsPlatformUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Виж билети
          </Button>
        </section>
      )}

      {hasDonation && (
        <section>
          <h2 class="font-serif text-2xl font-bold text-text-primary mb-4">Подкрепи работата ми</h2>
          <p class="text-text-secondary mb-6">
            Помогнете да подкрепя музиката ми и творчески проекти. Всеки принос помага да продължа да творя.
          </p>
          <Button
            variant="primary"
            href={siteConfig.donationUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Направи дарение
          </Button>
        </section>
      )}

      {hasAffiliates && (
        <section>
          <h2 class="font-serif text-2xl font-bold text-text-primary mb-4">Препоръчано</h2>
          <p class="text-text-secondary mb-6">
            Инструменти, оборудване и услуги, които използвам и препоръчвам.
          </p>
          <div class="grid gap-4 sm:grid-cols-2">
            {siteConfig.affiliateLinks.filter(link => link.url).map(link => (
              <Card hover={true}>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block"
                >
                  <h3 class="font-bold text-text-primary mb-1">{link.label}</h3>
                  {link.note && <p class="text-sm text-text-secondary">{link.note}</p>}
                </a>
              </Card>
            ))}
          </div>
        </section>
      )}

      {!hasMusic && !hasTickets && !hasDonation && !hasAffiliates && (
        <div class="text-center py-12">
          <p class="text-text-secondary text-lg">
            Опции за подкрепа скоро. Проверете отново или последвайте в социалните мрежи за актуализации!
          </p>
        </div>
      )}
    </div>
  </div>
</Layout>
