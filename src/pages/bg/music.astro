---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import releases from '../../data/releases.json';

const featuredRelease = releases.find(r => r.featured);
const otherReleases = releases.filter(r => !r.featured);
---

<Layout
  title="Музика - amioprenova"
  description="Изследвайте дискографията на Ами Опренова. Албуми, издания и линкове за слушане в Spotify, Bandcamp и Apple Music."
  lang="bg"
>
  <div class="max-w-6xl mx-auto">
    <PageHeader title="Музика" align="center" class="mb-12" />

    <!-- Featured Release -->
    {featuredRelease && (
      <section class="mb-20">
        <SectionHeader title="Ново Издание" class="mb-8" />
        <Card padding="lg" class="md:p-12 shadow-lg">
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div>
              <img src={featuredRelease.coverImage} alt={featuredRelease.title} class="w-full rounded-lg shadow-md" />
            </div>
            <div>
              <h3 class="font-serif text-3xl font-bold mb-2">{featuredRelease.title}</h3>
              <p class="text-xl text-text-secondary mb-4">{featuredRelease.year}</p>
              <p class="text-text-secondary mb-6 leading-relaxed">{featuredRelease.description}</p>
              <div class="flex flex-wrap gap-3">
                {featuredRelease.bandcampUrl && (
                  <Button href={featuredRelease.bandcampUrl} variant="primary" target="_blank" rel="noopener noreferrer" class="px-5 py-2 font-semibold">
                    Buy on Bandcamp
                  </Button>
                )}
                {featuredRelease.spotifyUrl && (
                  <Button href={featuredRelease.spotifyUrl} variant="secondary" target="_blank" rel="noopener noreferrer" class="px-5 py-2 font-semibold">
                    Spotify
                  </Button>
                )}
                {featuredRelease.appleMusicUrl && (
                  <Button href={featuredRelease.appleMusicUrl} variant="secondary" target="_blank" rel="noopener noreferrer" class="px-5 py-2 font-semibold">
                    Apple Music
                  </Button>
                )}
              </div>
            </div>
          </div>
        </Card>
      </section>
    )}

    <!-- All Releases Grid -->
    <section>
      <SectionHeader title="Дискография" class="mb-8" />
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {otherReleases.map(release => (
          <Card padding="none" hover class="overflow-hidden hover:shadow-xl">
            <img src={release.coverImage} alt={release.title} class="w-full aspect-square object-cover" />
            <div class="p-6">
              <h3 class="text-xl font-bold mb-1">{release.title}</h3>
              <p class="text-text-secondary mb-3">{release.year}</p>
              <p class="text-text-secondary text-sm mb-4 line-clamp-3">{release.description}</p>
              <div class="flex flex-wrap gap-2">
                {release.bandcampUrl && (
                  <Button href={release.bandcampUrl} variant="primary" target="_blank" rel="noopener noreferrer" class="text-sm px-3 py-1">
                    Buy
                  </Button>
                )}
                {release.spotifyUrl && (
                  <Button href={release.spotifyUrl} variant="secondary" target="_blank" rel="noopener noreferrer" class="text-sm px-3 py-1">
                    Spotify
                  </Button>
                )}
                {release.appleMusicUrl && (
                  <Button href={release.appleMusicUrl} variant="secondary" target="_blank" rel="noopener noreferrer" class="text-sm px-3 py-1">
                    Apple
                  </Button>
                )}
              </div>
            </div>
          </Card>
        ))}
      </div>
    </section>
  </div>
</Layout>
