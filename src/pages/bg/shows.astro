---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getUpcomingEvents, formatEventDate } from '../../lib/events';

const upcomingEvents = getUpcomingEvents();
---

<Layout
  title="Концерти - amioprenova"
  description="Намерете предстоящи концерти и изпълнения на amioprenova. Вземете билети и вижте дати, места и локации на концертите."
  lang="bg"
>
  <PageHeader title="Предстоящи концерти" class="nav:text-center" />

  {upcomingEvents.length === 0 ? (
    <p class="text-text-secondary text-lg">
      Няма предстоящи концерти в момента. Проверете отново скоро или последвайте в социалните мрежи за обяви!
    </p>
  ) : (
    <div class="space-y-6">
      {upcomingEvents.map(event => (
        <Card hover={true}>
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
            <div class="flex-grow">
              <h2 class="font-serif text-2xl font-bold mb-2">{event.title}</h2>
              <p class="text-text-secondary mb-1">
                <span class="font-medium">{formatEventDate(event.startDate, 'bg')}</span>
              </p>
              <p class="text-text-secondary">
                {event.venue} · {event.city}, {event.country}
              </p>
            </div>
            <div class="flex gap-3">
              {event.ticketUrl && (
                <Button
                  variant="primary"
                  href={event.ticketUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm"
                >
                  Билети
                </Button>
              )}
              {event.mapUrl && (
                <Button
                  variant="secondary"
                  href={event.mapUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm"
                >
                  Карта
                </Button>
              )}
            </div>
          </div>
        </Card>
      ))}
    </div>
  )}
</Layout>
