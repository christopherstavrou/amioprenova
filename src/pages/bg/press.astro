---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Card from '../../components/Card.astro';
import Badge from '../../components/Badge.astro';
import Button from '../../components/Button.astro';
import { siteConfig } from '../../config/site';
---

<Layout
  title="Преса - amioprenova"
  description="Преса кит и медийни ресурси за amioprenova. Високо качествени снимки, биография и контакт за преса."
  lang="bg"
>
  <PageHeader title="Преса / Медиа Кит" align="center" />

  <div class="max-w-4xl mx-auto">
    <!-- Short Bio -->
    <section class="mb-6">
      <h2 class="font-serif text-2xl font-bold mb-4">Кратка биография</h2>
      <div>
        <p class="text-lg leading-relaxed text-text-primary">
          amioprenova е музикант и композитор, създаващ атмосферни електронни звукови пейзажи, които съчетават ambient текстури с експериментална продукция. Базиран в София, България, техният труд изследва пресечната точка между органични и синтетични звуци.
        </p>
      </div>
    </section>

    <!-- Long Bio -->
    <section class="mb-6">
      <h2 class="font-serif text-2xl font-bold mb-4">Пълна биография</h2>
      <div>
        <p class="mb-4 text-text-primary">
          amioprenova е музикант, композитор и sound designer, чиято работа съществува на кръстопътя между електронния експеримент и емоционалното разказване. Вдъхновен от ambient пионерите, модерните електронни продуценти и природните звукови пейзажи на България, тяхната музика създава имерсивни звукови среди, които канят към дълбоко слушане.
        </p>
        <p class="mb-4 text-text-primary">
          От появата си на независимата музикална сцена, amioprenova е развил отличителен глас, характеризиращ се с наслоени синт текстури, field recordings и внимателно изградени ритмични елементи. Техният подход към композицията приоритизира атмосферата и емоционалния резонанс, създавайки музика, която служи едновременно като фонова медитация и преден план на наратива.
        </p>
        <p class="text-text-primary">
          С изпълнения, вариращи от интимни слушателни зали до фестивални сцени, amioprenova продължава да разширява границите на електронната музика, като същевременно поддържа достъпност и емоционална дълбочина. Техните творби са били представени в независими радиостанции и кюрирани плейлисти, изграждайки отдадена аудитория от слушатели, които оценяват внимателната, атмосферна електронна музика.
        </p>
      </div>
    </section>

    <!-- Genre & RIYL -->
    <section class="mb-6">
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h2 class="font-serif text-2xl font-bold mb-4">Жанр</h2>
          <div class="flex flex-wrap gap-2">
            {siteConfig.genres.map((genre) => (
              <Badge>{genre}</Badge>
            ))}
          </div>
        </div>
        <div>
          <h2 class="font-serif text-2xl font-bold mb-4">Препоръчано ако харесвате</h2>
          <div class="flex flex-wrap gap-2">
            {siteConfig.riylTags.map((artist) => (
              <Badge>{artist}</Badge>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Key Links -->
    <section class="mb-6">
      <h2 class="font-serif text-2xl font-bold mb-4">Връзки</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href={siteConfig.baseUrl} class="text-accent-primary hover:text-accent-primary-hover hover:underline transition-colors">Официален уебсайт</a>
        <a href={siteConfig.bandcampUrl} class="text-accent-primary hover:text-accent-primary-hover hover:underline transition-colors">Bandcamp</a>
        <a href={siteConfig.spotifyUrl} class="text-accent-primary hover:text-accent-primary-hover hover:underline transition-colors">Spotify</a>
        <a href={siteConfig.youtubeUrl} class="text-accent-primary hover:text-accent-primary-hover hover:underline transition-colors">YouTube</a>
        <a href={siteConfig.instagramUrl} class="text-accent-primary hover:text-accent-primary-hover hover:underline transition-colors">Instagram</a>
        <a href={siteConfig.facebookUrl} class="text-accent-primary hover:text-accent-primary-hover hover:underline transition-colors">Facebook</a>
      </div>
    </section>

    <!-- Downloads -->
    <section class="mb-6">
      <h2 class="font-serif text-2xl font-bold mb-4">Изтегляния</h2>
      <Card padding="lg" class="bg-surface-muted">
        <div class="space-y-6">
          <div>
            <h3 class="font-semibold text-text-primary mb-3">Преса снимки</h3>
            <div class="space-y-2">
              {siteConfig.pressAssets.photos.map((photo) => (
                <Button variant="secondary" href={photo} target="_blank" rel="noopener noreferrer" class="w-full justify-start">
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  Преса снимка (високо качество)
                </Button>
              ))}
            </div>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary mb-3">Лого</h3>
            <Button variant="secondary" href={siteConfig.pressAssets.logo} target="_blank" rel="noopener noreferrer" class="w-full justify-start">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Официално лого (PNG)
            </Button>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary mb-3">Технически райдър</h3>
            <Button variant="secondary" href={siteConfig.pressAssets.techRider} target="_blank" rel="noopener noreferrer" class="w-full justify-start">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Технически райдър (PDF)
            </Button>
          </div>
        </div>
      </Card>
    </section>

    <!-- Contact -->
    <section class="mb-6">
      <h2 class="font-serif text-2xl font-bold mb-4">Преса контакт</h2>
      <p class="text-lg text-text-primary">
        За преса запитвания, интервюта и медийни искания, моля свържете се с:{' '}
        <a
          href={`mailto:${siteConfig.pressEmail}?subject=Преса%20запитване`}
          class="text-accent-primary hover:text-accent-primary-hover hover:underline font-semibold transition-colors"
        >
          Преса контакт
        </a>
      </p>
    </section>
  </div>
</Layout>
