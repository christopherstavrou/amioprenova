---
import Layout from '../../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import Button from '../../components/Button.astro';
import PageHeader from '../../components/PageHeader.astro';

const about = await getEntry('pages', 'bg/about');
const { Content } = await about.render();
---

<Layout
  title={`${about.data.title} - amioprenova`}
  description={about.data.description}
  lang="bg"
>
  
    <!-- Portrait + Bio -->
    <div class="grid md:grid-cols-5 gap-8 mb-6 items-start">
      <!-- Portrait -->
      <div class="md:col-span-2">
        <img
          src="/images/ami-portrait.jpg"
          alt="Ами Опренова портрет"
          class="w-full rounded-lg shadow-xl object-cover"
          style="aspect-ratio: 3/4; object-position: center top;"
        />
      </div>

      <!-- Bio text -->
      <div class="md:col-span-3 pt-2">
        <PageHeader title={about.data.title} class="mb-6" />
        <div class="prose prose-lg max-w-none text-text-primary">
          <Content />
        </div>
      </div>
    </div>

    <!-- Performance Gallery Strip -->
    <section class="mb-8 -mx-4">
      <div class="grid grid-cols-3 gap-1">
        <div class="overflow-hidden">
          <img
            src="/images/performance-spice.jpg"
            alt="Ами Опренова в Spice of Life"
            class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500"
          />
        </div>
        <div class="overflow-hidden">
          <img
            src="/images/band-ensemble.jpg"
            alt="Ами Опренова с оркестъра"
            class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500"
          />
        </div>
        <div class="overflow-hidden">
          <img
            src="/images/duet.jpg"
            alt="Ами Опренова дует"
            class="w-full h-64 object-cover hover:scale-105 transition-transform duration-500"
          />
        </div>
      </div>
    </section>

    <!-- Отвъд сцената -->
    <section class="mb-8 -mx-4 relative">
      <img
        src="/images/family-portrait.jpg"
        alt="Ами Опренова семейство"
        class="w-full h-[420px] object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-bg/90 via-bg/30 to-transparent flex items-end">
        <div class="p-8 md:p-12 max-w-2xl">
          <h2 class="font-serif text-3xl md:text-4xl font-bold text-text-inverse mb-4">Отвъд Сцената</h2>
          <p class="text-text-inverse/90 text-lg leading-relaxed">
            Извън прожекторите Ами е отдадена майка и партньор. Семейството е ритъмът зад всяка
            нота — радостта, топлината и опорната точка, която вдъхва на музиката й истинско чувство.
          </p>
        </div>
      </div>
    </section>

    <!-- Press quote -->
    <section class="mb-8 text-center max-w-3xl mx-auto px-4">
      <blockquote class="font-serif text-2xl italic text-accent-secondary leading-relaxed mb-4">
        "Oprenova's rousing scat singing is full of excellent technical mastery with incredible falsetto…"
      </blockquote>
      <cite class="not-italic text-text-secondary font-semibold">— Italia in Jazz ★★★★★</cite>
    </section>

</Layout>
