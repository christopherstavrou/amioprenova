---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import cakeAndJazz from '../../data/cake-and-jazz.json';
---

<Layout
  title="Кейк и Джаз - amioprenova"
  description="Кейк и Джаз е уникална концертна поредица на Ами Опренова, която съчетава живо джаз изпълнение с най-изисканите артизански торти. Разгледайте албумите."
  lang="bg"
>
  
    <PageHeader title="Кейк и Джаз" class="mb-6 nav:text-center" />

    <!-- Introduction -->
    <p class="text-lg text-text-secondary nav:text-center max-w-2xl nav:mx-auto mb-8 leading-relaxed">
      Уникална концепция, в която живият джаз се среща с най-изисканите артизански торти. Всяко
      издание събира музика, вкус и общност за незабравима вечер на сетивно удоволствие.
    </p>

    <!-- Featured Video -->
    <section class="mb-10">
      <SectionHeader title="Гледайте" class="mb-8" />
      <div class="video-card" data-youtube-id={cakeAndJazz.video.youtubeId}>
        <button
          class="video-thumb w-full relative rounded-lg overflow-hidden shadow-lg cursor-pointer block"
          aria-label={`Пусни ${cakeAndJazz.video.title}`}
        >
          <img
            src={cakeAndJazz.video.thumbnail}
            alt={cakeAndJazz.video.title}
            class="w-full aspect-video object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 flex items-center justify-center bg-black/30 hover:bg-black/50 transition-colors">
            <svg class="w-24 h-24 text-white drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </button>
        <div class="video-player hidden aspect-video rounded-lg overflow-hidden bg-black"></div>
        <p class="mt-4 text-center text-text-secondary">{cakeAndJazz.video.title}</p>
      </div>
    </section>

    <!-- Albums -->
    <section>
      <SectionHeader title="Издания" class="mb-8" />
      <div class="space-y-6">
        {cakeAndJazz.albums.map(album => (
          <Card padding="none" hover={true} class="overflow-hidden">
            <div class="flex flex-col md:flex-row">
              <div class="md:w-64 lg:w-80 flex-shrink-0">
                <img
                  src={album.image}
                  alt={album.title}
                  class="w-full h-48 md:h-full object-cover"
                />
              </div>
              <div class="flex flex-col justify-center p-6 lg:p-8 gap-4">
                <h3 class="font-serif text-2xl font-bold">{album.title}</h3>
                <p class="text-text-secondary leading-relaxed">{album.description}</p>
                <div>
                  <Button href={album.albumUrl} variant="primary">
                    Виж Албума
                  </Button>
                </div>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </section>
</Layout>

<script>
  import '../../scripts/inline-video';
</script>
