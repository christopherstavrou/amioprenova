---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import PageHeader from '../../components/PageHeader.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { siteConfig } from '../../config/site';
import videos from '../../data/videos.json';

const featuredVideo = videos.find(v => v.featured);
const otherVideos = videos.filter(v => !v.featured);
---

<Layout
  title="Видео - amioprenova"
  description="Гледайте музикални клипове, концертни изпълнения и материали зад кулисите от Ами Опренова. Изследвайте визуалното изкуство и записи на живо."
  lang="bg"
>
  <PageHeader title="Видеа" align="center" class="mb-6" />

  <!-- Основно видео — пуска се вградено при клик -->
  {featuredVideo && (
    <section class="mb-10">
      <div class="video-card" data-youtube-id={featuredVideo.youtubeId}>
        <button
          class="video-thumb w-full relative rounded-lg overflow-hidden shadow-lg cursor-pointer block"
          aria-label={`Пусни ${featuredVideo.title}`}
        >
          <img
            src={featuredVideo.thumbnail}
            alt={featuredVideo.title}
            class="w-full aspect-video object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 flex items-center justify-center bg-black/30 hover:bg-black/50 transition-colors">
            <svg class="w-24 h-24 text-white drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </button>
        <div class="video-player hidden aspect-video rounded-lg overflow-hidden bg-black"></div>
        <div class="mt-6">
          <h2 class="font-serif text-2xl font-bold mb-2">{featuredVideo.title}</h2>
          <p class="text-text-secondary mb-2">{new Date(featuredVideo.date).toLocaleDateString('bg-BG', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
          <p class="text-text-secondary leading-relaxed">{featuredVideo.description}</p>
        </div>
      </div>
    </section>
  )}

  <!-- Още видеа — пускат се вградено при клик -->
  <section>
    <SectionHeader title="Още Видеа" class="mb-8" />
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {otherVideos.map(video => (
        <Card padding="none" hover={false} class="overflow-hidden">
          <div class="video-card" data-youtube-id={video.youtubeId}>
            <button
              class="video-thumb w-full block"
              aria-label={`Пусни ${video.title}`}
            >
              <div class="relative">
                <img
                  src={video.thumbnail}
                  alt={video.title}
                  class="w-full aspect-video object-cover"
                  loading="lazy"
                />
                <div class="absolute inset-0 flex items-center justify-center bg-black/30 hover:bg-black/50 transition-colors">
                  <svg class="w-14 h-14 text-white drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
            </button>
            <div class="video-player hidden aspect-video overflow-hidden bg-black"></div>
          </div>
          <div class="p-5">
            <h3 class="font-serif text-base font-bold mb-1 line-clamp-2">{video.title}</h3>
            <p class="text-sm text-text-secondary">{new Date(video.date).toLocaleDateString('bg-BG', { year: 'numeric', month: 'long' })}</p>
          </div>
        </Card>
      ))}
    </div>
  </section>

  <!-- Връзка към YouTube канал -->
  <div class="mt-10 text-center">
    <p class="text-text-secondary mb-4">Още изпълнения и записи в YouTube</p>
    <Button href={siteConfig.youtubeUrl} variant="secondary" target="_blank" rel="noopener noreferrer">
      YouTube канал
    </Button>
  </div>
</Layout>

<script>
  import '../../scripts/inline-video';
</script>
