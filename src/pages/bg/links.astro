---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import { siteConfig } from '../../config/site';

const activeLinks = siteConfig.linksPageLinks.filter(link => link.url);
---

<Layout
  title="Връзки - amioprenova"
  description="Всички връзки на едно място. Последвайте amioprenova в социалните мрежи, слушайте музика и намерете всички платформи тук."
  lang="bg"
>
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-8">
      <h1 class="font-serif text-4xl font-bold text-text-primary mb-3">amioprenova</h1>
      <p class="text-text-secondary">Всички мои връзки на едно място</p>
    </div>

    {activeLinks.length > 0 ? (
      <div class="space-y-4">
        {activeLinks.map(link => (
          <Button
            variant="secondary"
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full text-center"
          >
            {link.label}
          </Button>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-text-secondary text-lg">
          Връзки скоро. Проверете отново по-късно!
        </p>
      </div>
    )}
  </div>
</Layout>
