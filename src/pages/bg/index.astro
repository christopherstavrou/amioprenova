---
import Layout from '../../layouts/Layout.astro';
import { getNextEvents, formatEventDate } from '../../lib/events';

const nextShows = getNextEvents(3);
---

<Layout title="Начало - amioprenova" lang="bg">
  <div class="max-w-4xl">
    <h1 class="text-5xl font-bold mb-6">Добре дошли</h1>
    <p class="text-xl text-gray-600 mb-12">
      Музикант · Композитор · Изпълнител
    </p>

    {nextShows.length > 0 && (
      <section class="mt-12">
        <div class="flex justify-between items-baseline mb-6">
          <h2 class="text-3xl font-bold">Предстоящи концерти</h2>
          <a href="/bg/shows" class="text-sm text-gray-600 hover:text-gray-900 underline">
            Виж всички концерти
          </a>
        </div>
        <div class="space-y-4">
          {nextShows.map(event => (
            <div class="border border-gray-200 rounded-lg p-5 hover:border-gray-300 transition-colors">
              <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3">
                <div class="flex-grow">
                  <h3 class="text-xl font-bold mb-1">{event.title}</h3>
                  <p class="text-sm text-gray-600 mb-1">
                    {formatEventDate(event.startDate, 'bg')}
                  </p>
                  <p class="text-sm text-gray-600">
                    {event.venue} · {event.city}, {event.country}
                  </p>
                </div>
                <div class="flex gap-2">
                  {event.ticketUrl && (
                    <a
                      href={event.ticketUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-block px-3 py-1.5 bg-gray-900 text-white text-sm rounded hover:bg-gray-700 transition-colors"
                    >
                      Билети
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
