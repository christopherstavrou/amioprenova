---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import Card from '../../../components/Card.astro';
import PageHeader from '../../../components/PageHeader.astro';
import Badge from '../../../components/Badge.astro';
import ShowActionsMenu from '../../../components/ShowActionsMenu.astro';
import SearchInput from '../../../components/SearchInput.astro';
import { getUpcomingEvents, getPastEvents, formatEventDate } from '../../../lib/events';
import { siteConfig } from '../../../config/site';

export const getStaticPaths = (async ({ paginate }) => {
  const upcomingEvents = await getUpcomingEvents();
  if (upcomingEvents.length === 0) {
    return [{ params: { page: undefined }, props: { page: { data: [], currentPage: 1, lastPage: 1, url: { prev: null, next: null } } } }];
  }
  return paginate(upcomingEvents, { pageSize: 6 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const events = page.data;
const pastEvents = await getPastEvents();

const locationLine = (event: { venue: string; city: string; country: string }) =>
  [event.venue, [event.city, event.country].filter(Boolean).join(', ')].filter(Boolean).join(' · ');
const eventTitle = (event: typeof events[number]) => event.titleBg || (event.titleEn ? '' : event.title) || event.title;
const eventDescription = (event: typeof events[number]) => event.descriptionBg || (event.descriptionEn ? '' : event.description) || event.description;
const eventTags = (event: typeof events[number]) => event.tagsBg ?? event.tags ?? [];
---

<Layout
  title={page.currentPage === 1 ? "Концерти - amioprenova" : `Концерти - Страница ${page.currentPage} - amioprenova`}
  description="Намерете предстоящи концерти и изпълнения на amioprenova. Вземете билети и вижте дати, места и локации на концертите."
  lang="bg"
>
  <PageHeader title="Предстоящи концерти" class="nav:text-center" />

  <div class="max-w-4xl mx-auto">
    <div class="flex justify-end mb-8">
      <SearchInput labels={{ placeholder: 'Търсене на концерти...' }} />
    </div>

    {events.length === 0 ? (
      <p class="text-text-secondary text-lg">
        Няма предстоящи концерти в момента. Проверете отново скоро или последвайте в социалните мрежи за обяви!
      </p>
    ) : (
      <div class="space-y-3 mb-6">
        {events.map(event => (
          <Card hover={true} padding="none">
            <div class="flex flex-col sm:flex-row">
              {event.image && (
                <a href={`/bg/shows/${event.slug}`} class="overflow-hidden rounded-t-md sm:rounded-t-none sm:rounded-l-md sm:shrink-0 sm:w-44">
                  <img
                    src={event.image}
                    alt={event.title}
                    class="w-full aspect-[3/1] sm:aspect-auto sm:h-full object-cover hover:scale-105 transition-transform duration-fast"
                    loading="lazy"
                  />
                </a>
              )}
              <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3 p-4 flex-1 min-w-0">
                <div class="flex-grow min-w-0">
                  <a href={`/bg/shows/${event.slug}`} class="group">
                    <h2 class="font-serif text-lg font-bold mb-1 leading-snug group-hover:text-accent-primary transition-colors">
                      {eventTitle(event)}
                    </h2>
                  </a>
                  <p class="text-text-secondary text-sm mb-1">
                    <span class="font-medium">{formatEventDate(event.startDate, 'bg')}</span>
                  </p>
                  {locationLine(event) && <p class="text-text-secondary text-sm mb-2">{locationLine(event)}</p>}
                  {eventTags(event).length > 0 && (
                    <div class="flex gap-1.5 flex-wrap mb-2">
                      {eventTags(event).map(tag => (
                        <Badge>{tag}</Badge>
                      ))}
                    </div>
                  )}
                  <p class="text-text-primary text-sm line-clamp-2">
                    {eventDescription(event)}
                  </p>
                </div>
                <div class="shrink-0">
                  <ShowActionsMenu
                    items={[
                      ...(event.ticketUrl ? [{ href: event.ticketUrl, label: 'Билети', icon: 'ticket' as const }] : []),
                      ...(event.mapUrl ? [{ href: event.mapUrl, label: 'Карта', icon: 'map' as const }] : []),
                      ...(event.sourceUrl ? [{ href: event.sourceUrl, label: 'Фейсбук', icon: 'facebook' as const }] : []),
                    ]}
                    shareUrl={`${siteConfig.baseUrl}/bg/shows/${event.slug}`}
                    shareTitle={eventTitle(event)}
                    labels={{ menu: 'Действия за концерта', share: 'Сподели', copyLink: 'Копирай линк', copied: 'Копирано!', facebook: 'Фейсбук', twitter: 'Twitter / X' }}
                  />
                </div>
              </div>
            </div>
          </Card>
        ))}
      </div>
    )}

    {/* Pagination */}
    {(page.lastPage > 1) && (
      <nav class="flex justify-between items-center border-t border-border pt-8 mb-12">
        <div>
          {page.url.prev ? (
            <a
              href={page.url.prev}
              class="inline-block px-4 py-2 border border-border rounded hover:border-accent-primary hover:text-accent-primary transition-colors"
            >
              ← Предишна
            </a>
          ) : (
            <span class="inline-block px-4 py-2 border border-border-light rounded text-text-secondary cursor-not-allowed opacity-50">
              ← Предишна
            </span>
          )}
        </div>

        <span class="text-sm text-text-secondary">
          Страница {page.currentPage} от {page.lastPage}
        </span>

        <div>
          {page.url.next ? (
            <a
              href={page.url.next}
              class="inline-block px-4 py-2 border border-border rounded hover:border-accent-primary hover:text-accent-primary transition-colors"
            >
              Следваща →
            </a>
          ) : (
            <span class="inline-block px-4 py-2 border border-border-light rounded text-text-secondary cursor-not-allowed opacity-50">
              Следваща →
            </span>
          )}
        </div>
      </nav>
    )}

    {/* Past shows */}
    {pastEvents.length > 0 && (
      <div class="border-t border-border pt-8">
        <button
          id="past-shows-toggle"
          class="flex items-center gap-2 text-sm font-medium text-text-secondary hover:text-accent-primary transition-colors mb-6"
          aria-expanded="false"
          aria-controls="past-shows-list"
        >
          <svg id="past-shows-chevron" class="w-4 h-4 transition-transform duration-fast" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          Покажи минали концерти ({pastEvents.length})
        </button>

        <div id="past-shows-list" class="hidden space-y-3">
          {pastEvents.map(event => (
            <Card hover={true} padding="none">
              <div class="flex flex-col sm:flex-row">
                {event.image && (
                  <a href={`/bg/shows/${event.slug}`} class="overflow-hidden rounded-t-md sm:rounded-t-none sm:rounded-l-md sm:shrink-0 sm:w-44">
                    <img
                      src={event.image}
                      alt={event.title}
                      class="w-full aspect-[3/1] sm:aspect-auto sm:h-full object-cover hover:scale-105 transition-transform duration-fast"
                      loading="lazy"
                    />
                  </a>
                )}
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3 p-4 flex-1 min-w-0">
                  <div class="flex-grow min-w-0">
                    <a href={`/bg/shows/${event.slug}`} class="group">
                      <h2 class="font-serif text-lg font-bold mb-1 leading-snug group-hover:text-accent-primary transition-colors">
                        {eventTitle(event)}
                      </h2>
                    </a>
                    <p class="text-text-secondary text-sm mb-1">
                      <span class="font-medium">{formatEventDate(event.startDate, 'bg')}</span>
                    </p>
                    {locationLine(event) && <p class="text-text-secondary text-sm mb-2">{locationLine(event)}</p>}
                    {eventTags(event).length > 0 && (
                      <div class="flex gap-1.5 flex-wrap mb-2">
                        {eventTags(event).map(tag => (
                          <Badge>{tag}</Badge>
                        ))}
                      </div>
                    )}
                    <p class="text-text-primary text-sm line-clamp-2">
                      {eventDescription(event)}
                    </p>
                  </div>
                  <div class="shrink-0">
                    <ShowActionsMenu
                      items={[
                        ...(event.ticketUrl ? [{ href: event.ticketUrl, label: 'Билети', icon: 'ticket' as const }] : []),
                        ...(event.mapUrl ? [{ href: event.mapUrl, label: 'Карта', icon: 'map' as const }] : []),
                        ...(event.sourceUrl ? [{ href: event.sourceUrl, label: 'Фейсбук', icon: 'facebook' as const }] : []),
                      ]}
                      shareUrl={`${siteConfig.baseUrl}/bg/shows/${event.slug}`}
                      shareTitle={eventTitle(event)}
                      labels={{ menu: 'Действия за концерта', share: 'Сподели', copyLink: 'Копирай линк', copied: 'Копирано!', facebook: 'Фейсбук', twitter: 'Twitter / X' }}
                    />
                  </div>
                </div>
              </div>
            </Card>
          ))}
        </div>
      </div>
    )}
  </div>

  <script>
    import { initListSearch } from '../../../scripts/list-search';
    initListSearch({ type: 'event', lang: 'bg' });

    // Past shows toggle
    const toggleBtn = document.getElementById('past-shows-toggle');
    const pastList  = document.getElementById('past-shows-list');
    const chevron   = document.getElementById('past-shows-chevron');
    if (toggleBtn && pastList && chevron) {
      toggleBtn.addEventListener('click', () => {
        const isHidden = pastList.classList.contains('hidden');
        pastList.classList.toggle('hidden');
        chevron.style.transform = isHidden ? 'rotate(90deg)' : '';
        toggleBtn.setAttribute('aria-expanded', String(isHidden));
      });
    }
  </script>
</Layout>
