---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Card from '../../components/Card.astro';
import Button from '../../components/Button.astro';
import { siteConfig } from '../../config/site';

// Booking mailto template
const bookingSubject = encodeURIComponent('Запитване за резервация');
const bookingBody = encodeURIComponent(`Здравейте,

Бих искал/а да направя запитване за резервация на изпълнение.

Детайли:
- Име/Организация:
- Място:
- Град, Държава:
- Предпочитани дати:
- Бюджет:
- Продължителност на сета:
- Технически изисквания:
- Допълнителна информация:

Връзки:
- Уебсайт:
- Социални мрежи:

Благодаря!`);

const bookingMailto = `mailto:${siteConfig.bookingEmail}?subject=${bookingSubject}&body=${bookingBody}`;

// Press mailto template
const pressSubject = encodeURIComponent('Медийно запитване');
const pressBody = encodeURIComponent(`Здравейте,

Свързвам се с вас относно медийно запитване.

Детайли:
- Издание/Публикация:
- Краен срок:
- Необходимо (интервю, снимки, биография и др.):
- Информация за контакт:
- Допълнителна информация:

Благодаря!`);

const pressMailto = `mailto:${siteConfig.pressEmail}?subject=${pressSubject}&body=${pressBody}`;
---

<Layout
  title="Контакт - amioprenova"
  description="Свържете се с amioprenova за запитвания за резервации, медийни заявки и общи въпроси. Контакт чрез имейл."
  lang="bg"
>
  <PageHeader title="Контакт" />

  <div class="max-w-2xl mx-auto">
    <p class="text-lg text-text-secondary mb-6">
      Свържете се за резервации, медийни запитвания или общи въпроси.
    </p>

    <div class="grid gap-6 sm:grid-cols-2 mb-6">
      <Card hover={true} class="text-center">
        <h2 class="font-serif text-2xl font-bold text-text-primary mb-2">Резервация</h2>
        <p class="text-sm text-text-secondary mb-6">
          Запитване за изпълнения, концерти и участия
        </p>
        <Button variant="primary" href={bookingMailto} class="w-full">
          Изпратете запитване
        </Button>
      </Card>

      <Card hover={true} class="text-center">
        <h2 class="font-serif text-2xl font-bold text-text-primary mb-2">Преса</h2>
        <p class="text-sm text-text-secondary mb-6">
          Медийни запитвания, интервюта и пресматериали
        </p>
        <Button variant="primary" href={pressMailto} class="w-full">
          Изпратете запитване
        </Button>
      </Card>
    </div>

    <Card class="bg-surface-muted">
      <p class="text-sm text-text-secondary text-center">
        Моля, изчакайте 2-3 работни дни за отговор. За спешни въпроси, моля посочете това във вашето съобщение.
      </p>
    </Card>
  </div>
</Layout>
