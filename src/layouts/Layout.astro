---
import { ui, type Language } from '../i18n/ui';
import { siteConfig } from '../config/site';

export interface Props {
  title: string;
  description: string;
  lang: Language;
  ogImage?: string;
}

const { title, description, lang, ogImage } = Astro.props;
const t = ui[lang];

// SEO: Canonical URL
const canonicalURL = new URL(Astro.url.pathname, siteConfig.baseUrl).href;

// SEO: OpenGraph image
const ogImageUrl = new URL(ogImage || siteConfig.ogImage, siteConfig.baseUrl).href;

const navItems = [
  { href: `/${lang}`, label: t.nav.home },
  { href: `/${lang}/about`, label: t.nav.about },
  { href: `/${lang}/music`, label: t.nav.music },
  { href: `/${lang}/video`, label: t.nav.video },
  { href: `/${lang}/shows`, label: t.nav.shows },
  { href: `/${lang}/support`, label: t.nav.support },
  { href: `/${lang}/blog`, label: t.nav.news },
  { href: `/${lang}/press`, label: t.nav.press },
  { href: `/${lang}/contact`, label: t.nav.contact },
  { href: `/${lang}/links`, label: t.nav.links },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO: Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO: OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'bg_BG'} />

    <!-- SEO: Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900">
    <header class="border-b border-gray-200">
      <div class="container mx-auto px-4 py-4">
        <div class="flex justify-between items-center">
          <nav class="flex gap-6 flex-wrap">
            {navItems.map(item => (
              <a
                href={item.href}
                class="text-sm hover:text-gray-600 transition-colors"
              >
                {item.label}
              </a>
            ))}
          </nav>

          <div class="relative">
            <select
              id="language-switcher"
              class="appearance-none border border-gray-300 rounded px-3 py-1 text-sm bg-white cursor-pointer hover:border-gray-400"
            >
              <option value="en" selected={lang === 'en'}>EN</option>
              <option value="bg" selected={lang === 'bg'}>BG</option>
            </select>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-grow container mx-auto px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-auto">
      <div class="container mx-auto px-4 py-6 text-center text-sm text-gray-600">
        <p>&copy; {new Date().getFullYear()} {siteConfig.copyrightName}. {t.footer.copyright}</p>
      </div>
    </footer>

    <script>
      // Language switcher functionality
      const languageSwitcher = document.getElementById('language-switcher') as HTMLSelectElement;

      // Get current path and language
      const currentPath = window.location.pathname;
      const currentLang = currentPath.startsWith('/bg') ? 'bg' : 'en';

      // Set the correct option
      if (languageSwitcher) {
        languageSwitcher.value = currentLang;

        // Store language preference
        const storedLang = localStorage.getItem('preferred-language');
        if (storedLang && storedLang !== currentLang) {
          languageSwitcher.value = storedLang;
        }

        // Handle language change
        languageSwitcher.addEventListener('change', (e) => {
          const newLang = (e.target as HTMLSelectElement).value;
          localStorage.setItem('preferred-language', newLang);

          // Replace current language in path
          let newPath = currentPath;
          if (currentPath.startsWith('/en')) {
            newPath = currentPath.replace(/^\/en/, `/${newLang}`);
          } else if (currentPath.startsWith('/bg')) {
            newPath = currentPath.replace(/^\/bg/, `/${newLang}`);
          } else if (currentPath === '/') {
            newPath = `/${newLang}`;
          } else {
            newPath = `/${newLang}${currentPath}`;
          }

          window.location.href = newPath;
        });
      }
    </script>
  </body>
</html>
