---
import { ui, type Language } from '../i18n/ui';
import { siteConfig } from '../config/site';
import Logo from '../components/Logo.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  lang: Language;
  ogImage?: string;
}

const { title, description, lang, ogImage } = Astro.props;
const t = ui[lang];

// SEO: Canonical URL
const canonicalURL = new URL(Astro.url.pathname, siteConfig.baseUrl).href;

// SEO: OpenGraph image
const ogImageUrl = new URL(ogImage || siteConfig.ogImage, siteConfig.baseUrl).href;

const navItems = [
  { href: `/${lang}`, label: t.nav.home },
  { href: `/${lang}/about`, label: t.nav.about },
  { href: `/${lang}/music`, label: t.nav.music },
  { href: `/${lang}/video`, label: t.nav.video },
  { href: `/${lang}/cake-and-jazz`, label: t.nav.cakeAndJazz },
  { href: `/${lang}/shows`, label: t.nav.shows },
  { href: `/${lang}/support`, label: t.nav.support },
  { href: `/${lang}/blog`, label: t.nav.news },
  { href: `/${lang}/press`, label: t.nav.press },
  { href: `/${lang}/contact`, label: t.nav.contact },
  { href: `/${lang}/links`, label: t.nav.links },
];

// Check if current page is active
const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === `/${lang}`) {
    return currentPath === href || currentPath === `/${lang}/`;
  }
  return currentPath.startsWith(href);
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO: Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO: OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'bg_BG'} />

    <!-- SEO: Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Inline theme script to prevent FOUC -->
    <script is:inline>
      // Apply theme immediately before page renders
      (function() {
        function getCookie(name) {
          const value = '; ' + document.cookie;
          const parts = value.split('; ' + name + '=');
          if (parts.length === 2) return parts.pop().split(';').shift();
          return null;
        }

        function getSystemTheme() {
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        const savedTheme = getCookie('site_theme');
        const theme = (savedTheme === 'light' || savedTheme === 'dark') ? savedTheme : getSystemTheme();
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-text-primary">
    <!-- Sticky Glass Header -->
    <header class="header-glass sticky top-0 z-50 border-b">
      <div class="container mx-auto px-4 py-4">
        <div class="flex justify-between items-center gap-4">
          <!-- Logo -->
          <a href={`/${lang}`} class="flex-shrink-0 hover:opacity-80 transition-opacity">
            <Logo />
          </a>

          <!-- Desktop Navigation -->
          <nav class="hidden lg:flex gap-6 flex-1 justify-center">
            {navItems.map(item => (
              <a
                href={item.href}
                class={`text-sm font-medium transition-colors ${
                  isActive(item.href)
                    ? 'text-accent-primary'
                    : 'text-text-primary hover:text-accent-primary'
                }`}
              >
                {item.label}
              </a>
            ))}
          </nav>

          <!-- Desktop Controls: Theme Toggle + Language Switcher -->
          <div class="hidden lg:flex items-center gap-4">
            <!-- Theme Toggle Button -->
            <button
              id="theme-toggle"
              type="button"
              class="p-2 rounded-lg hover:bg-surface-muted transition-colors"
              aria-label="Toggle theme"
            >
              <svg class="w-5 h-5 sun-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              <svg class="w-5 h-5 moon-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
              </svg>
            </button>

            <!-- Language Switcher -->
            <select
              id="language-switcher"
              class="appearance-none border border-border rounded-md px-3 py-2 text-sm bg-surface text-text-primary cursor-pointer hover:border-accent-primary focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent transition-colors"
            >
              <option value="en" selected={lang === 'en'}>EN</option>
              <option value="bg" selected={lang === 'bg'}>BG</option>
            </select>
          </div>

          <!-- Mobile Hamburger Button -->
          <button
            id="mobile-menu-toggle"
            type="button"
            class="lg:hidden p-2 rounded-lg hover:bg-surface-muted transition-colors"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <svg class="w-6 h-6 hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg class="w-6 h-6 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu Overlay -->
      <div
        id="mobile-menu"
        class="mobile-menu lg:hidden fixed inset-0 opacity-0 invisible transition-all duration-300 ease-in-out overflow-y-auto"
      >
        <div class="container mx-auto px-4 py-6 pt-24">
          <nav class="flex flex-col items-center gap-4 mb-6">
            {navItems.map(item => (
              <a
                href={item.href}
                class={`text-lg font-medium py-2 transition-colors ${
                  isActive(item.href)
                    ? 'text-accent-primary'
                    : 'text-text-primary hover:text-accent-primary'
                }`}
              >
                {item.label}
              </a>
            ))}
          </nav>

          <!-- Mobile Controls -->
          <div class="flex flex-col items-center gap-4 pt-4 border-t border-border">
            <!-- Theme Toggle in Mobile -->
            <button
              id="mobile-theme-toggle"
              type="button"
              class="flex items-center justify-center gap-3 py-2 text-text-primary hover:text-accent-primary transition-colors"
            >
              <svg class="w-5 h-5 sun-icon-mobile" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              <svg class="w-5 h-5 moon-icon-mobile hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
              </svg>
              <span id="theme-label">Toggle Theme</span>
            </button>

            <!-- Language Switcher in Mobile -->
            <select
              id="mobile-language-switcher"
              class="appearance-none border border-border rounded-md px-3 py-2 text-sm bg-surface text-text-primary cursor-pointer hover:border-accent-primary focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent transition-colors"
            >
              <option value="en" selected={lang === 'en'}>EN</option>
              <option value="bg" selected={lang === 'bg'}>BG</option>
            </select>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-grow container mx-auto px-4 pt-2 pb-6">
      <slot />
    </main>

    <footer class="border-t border-border mt-auto bg-surface">
      <div class="container mx-auto px-4 py-6">
        <!-- Social Links -->
        <div class="flex justify-center gap-6 mb-6">
          {siteConfig.instagramUrl && (
            <a href={siteConfig.instagramUrl} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-accent-primary transition-colors" aria-label="Instagram">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
              </svg>
            </a>
          )}
          {siteConfig.facebookUrl && (
            <a href={siteConfig.facebookUrl} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-accent-primary transition-colors" aria-label="Facebook">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
              </svg>
            </a>
          )}
          {siteConfig.youtubeUrl && (
            <a href={siteConfig.youtubeUrl} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-accent-primary transition-colors" aria-label="YouTube">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z" clip-rule="evenodd" />
              </svg>
            </a>
          )}
          {siteConfig.bandcampUrl && (
            <a href={siteConfig.bandcampUrl} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-accent-primary transition-colors" aria-label="Bandcamp">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M0 8v8h8.75l6-8H24V8H0z" />
              </svg>
            </a>
          )}
          {siteConfig.spotifyUrl && (
            <a href={siteConfig.spotifyUrl} target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-accent-primary transition-colors" aria-label="Spotify">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
              </svg>
            </a>
          )}
        </div>

        <!-- Copyright -->
        <div class="text-center text-sm text-text-secondary">
          <p>&copy; {new Date().getFullYear()} {siteConfig.copyrightName}. {t.footer.copyright}</p>
        </div>
      </div>
    </footer>

    <script>
      // ===== Cookie Helper Functions =====
      function setCookie(name: string, value: string, days: number = 365) {
        const maxAge = days * 24 * 60 * 60;
        document.cookie = `${name}=${value}; path=/; max-age=${maxAge}; SameSite=Lax`;
      }

      function getCookie(name: string): string | null {
        const value = `; ${document.cookie}`;
        const parts = value.split(`; ${name}=`);
        if (parts.length === 2) {
          const cookieValue = parts.pop();
          return cookieValue ? cookieValue.split(';').shift() || null : null;
        }
        return null;
      }

      // ===== Theme Management =====
      const themeToggle = document.getElementById('theme-toggle');
      const mobileThemeToggle = document.getElementById('mobile-theme-toggle');

      const sunIcons = document.querySelectorAll('.sun-icon, .sun-icon-mobile');
      const moonIcons = document.querySelectorAll('.moon-icon, .moon-icon-mobile');

      function getSystemTheme(): 'light' | 'dark' {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }

      function getCurrentTheme(): 'light' | 'dark' {
        const savedTheme = getCookie('site_theme');
        if (savedTheme === 'light' || savedTheme === 'dark') {
          return savedTheme;
        }
        return getSystemTheme();
      }

      function updateThemeIcons(theme: 'light' | 'dark') {
        if (theme === 'dark') {
          sunIcons.forEach(icon => icon.classList.remove('hidden'));
          moonIcons.forEach(icon => icon.classList.add('hidden'));
        } else {
          sunIcons.forEach(icon => icon.classList.add('hidden'));
          moonIcons.forEach(icon => icon.classList.remove('hidden'));
        }
      }

      function applyTheme(theme: 'light' | 'dark') {
        // Set data-theme attribute on html element
        document.documentElement.setAttribute('data-theme', theme);
        updateThemeIcons(theme);
      }

      function toggleTheme() {
        const currentTheme = getCurrentTheme();
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        setCookie('site_theme', newTheme, 365);
        applyTheme(newTheme);
      }

      // Initialize theme on page load
      const initialTheme = getCurrentTheme();
      applyTheme(initialTheme);

      // Theme toggle event listeners
      if (themeToggle) {
        themeToggle.addEventListener('click', toggleTheme);
      }
      if (mobileThemeToggle) {
        mobileThemeToggle.addEventListener('click', toggleTheme);
      }

      // ===== Mobile Menu Toggle =====
      const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.querySelector('.hamburger-icon');
      const closeIcon = document.querySelector('.close-icon');

      let menuOpen = false;

      function toggleMobileMenu() {
        menuOpen = !menuOpen;

        if (menuOpen) {
          mobileMenu?.classList.add('open');
          hamburgerIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
          mobileMenuToggle?.setAttribute('aria-expanded', 'true');
          document.body.style.overflow = 'hidden';
        } else {
          mobileMenu?.classList.remove('open');
          hamburgerIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
          mobileMenuToggle?.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        }
      }

      if (mobileMenuToggle) {
        mobileMenuToggle.addEventListener('click', toggleMobileMenu);
      }

      // Close mobile menu when clicking a nav link
      const mobileNavLinks = mobileMenu?.querySelectorAll('nav a');
      mobileNavLinks?.forEach(link => {
        link.addEventListener('click', () => {
          if (menuOpen) {
            toggleMobileMenu();
          }
        });
      });

      // ===== Language Switcher =====
      const languageSwitcher = document.getElementById('language-switcher') as HTMLSelectElement;
      const mobileLanguageSwitcher = document.getElementById('mobile-language-switcher') as HTMLSelectElement;

      const currentPath = window.location.pathname;
      const currentLang = currentPath.startsWith('/bg') ? 'bg' : 'en';

      function handleLanguageChange(newLang: string) {
        setCookie('site_lang', newLang, 365);

        let newPath = currentPath;
        if (currentPath.startsWith('/en')) {
          newPath = currentPath.replace(/^\/en/, `/${newLang}`);
        } else if (currentPath.startsWith('/bg')) {
          newPath = currentPath.replace(/^\/bg/, `/${newLang}`);
        } else if (currentPath === '/') {
          newPath = `/${newLang}`;
        } else {
          newPath = `/${newLang}${currentPath}`;
        }

        window.location.href = newPath;
      }

      // Set correct language option on both selectors
      if (languageSwitcher) {
        languageSwitcher.value = currentLang;
        languageSwitcher.addEventListener('change', (e) => {
          const newLang = (e.target as HTMLSelectElement).value;
          handleLanguageChange(newLang);
        });
      }

      if (mobileLanguageSwitcher) {
        mobileLanguageSwitcher.value = currentLang;
        mobileLanguageSwitcher.addEventListener('change', (e) => {
          const newLang = (e.target as HTMLSelectElement).value;
          handleLanguageChange(newLang);
        });
      }

      // Check for stored language preference
      const storedLang = getCookie('site_lang');
      if (storedLang && storedLang !== currentLang && (storedLang === 'en' || storedLang === 'bg')) {
        // User has a language preference that differs from current page
        // You can optionally redirect here, or just update the selectors
        if (languageSwitcher) languageSwitcher.value = storedLang;
        if (mobileLanguageSwitcher) mobileLanguageSwitcher.value = storedLang;
      }
    </script>
  </body>
</html>
