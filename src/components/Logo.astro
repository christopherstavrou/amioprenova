---
/**
 * Logo Component
 *
 * Displays "Ami Oprenova" as an SVG text element using the Dancing Script font.
 * The logo adapts to the current theme (light/dark) automatically.
 *
 * Props:
 * - class: Optional additional CSS classes
 */

export interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class={`logo ${className}`}
  viewBox="0 0 300 60"
  xmlns="http://www.w3.org/2000/svg"
  aria-labelledby="logo-title"
  role="img"
>
  <defs>
    <linearGradient id="logo-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" />
      <stop offset="50%" />
      <stop offset="100%" />
    </linearGradient>
  </defs>
  <title id="logo-title">Ami Oprenova</title>
  <text
    x="4"
    y="30"
    text-anchor="start"
    dominant-baseline="middle"
    class="logo-text"
  >
    Ami Oprenova
  </text>
</svg>

<style>
  .logo {
    width: auto;
    height: 4rem;
    display: block;
  }

  .logo-text {
    font-family: 'Dancing Script', 'Pacifico', cursive, serif;
    font-size: 42px;
    font-weight: 400;
    fill: url(#logo-gradient);
  }

/* Larger on desktop */
  @media (min-width: 768px) {
    .logo {
      height: 5rem;
    }
  }

</style>
