---
/**
 * Logo Component
 *
 * Displays "Ami Oprenova" as styled HTML text using the Dancing Script font
 * with a CSS gradient applied via background-clip: text.
 *
 * Uses the same technique as h1 headings (--gradient-hero CSS variable),
 * which is reliably supported across all browsers including iOS Safari.
 * The previous SVG + linearGradient approach had iOS Safari compatibility
 * issues with CSS custom properties inside SVG <defs>.
 *
 * Props:
 * - class: Optional additional CSS classes
 */

export interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class={`logo-text ${className}`} aria-label="Ami Oprenova">Ami Oprenova</span>

<style>
  .logo-text {
    font-family: 'Dancing Script', 'Pacifico', cursive;
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1.2;
    white-space: nowrap;
    display: inline-block;
    padding-bottom: 0.1em; /* prevent descender clipping from background-clip: text */
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  @media (min-width: 768px) {
    .logo-text {
      font-size: 3.5rem;
    }
  }
</style>
