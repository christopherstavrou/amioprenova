---
/**
 * SectionHeader component
 * Consistent section title with optional description
 * Based on DESIGN.md typography specifications
 */

export interface Props {
  title: string;
  description?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  title,
  description,
  align = 'left',
  class: className = ''
} = Astro.props;

const alignClasses = align === 'center' ? 'text-center' : 'text-left';
---

<div class={`mb-12 ${alignClasses} ${className}`}>
  <h2 class="font-serif text-3xl md:text-4xl font-bold text-text-primary mb-4">
    {title}
  </h2>
  {description && (
    <p class="text-lg text-text-secondary max-w-prose mx-auto">
      {description}
    </p>
  )}
</div>
