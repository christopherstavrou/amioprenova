---
/**
 * GalleryLightbox
 * Compact thumbnail grid + full-screen lightbox with carousel.
 * - Theme-aware overlay (light/dark via :root[data-theme])
 * - z-[60]: above sticky nav (z-50)
 * - True flex layout: no vh arithmetic, works in portrait and landscape
 * - Safe-area-inset padding for iOS notch / home indicator
 * - Keyboard: Escape, ArrowLeft, ArrowRight
 * - Accessible: aria-modal, aria-label, focus management
 */
import type { GalleryItem } from '../lib/events';

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;

function thumbSrc(item: GalleryItem): string {
  if (item.type === 'youtube') return `https://img.youtube.com/vi/${item.id}/mqdefault.jpg`;
  if (item.type === 'image') return item.src;
  return '';
}

function itemLabel(item: GalleryItem): string {
  if (item.type === 'image') return item.alt;
  return item.title;
}

const itemsJson = JSON.stringify(items.map(item => {
  if (item.type === 'image') return { type: 'image', src: item.src, alt: item.alt ?? '', caption: item.caption ?? '' };
  if (item.type === 'youtube') return { type: 'youtube', id: item.id, title: item.title };
  return { type: 'vimeo', id: item.id, title: item.title };
}));
---

<!-- ─── Thumbnail grid ─────────────────────────────────────────────── -->
<div
  class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2 gallery-grid"
  data-gallery-items={itemsJson}
>
  {items.map((item, i) => (
    <button
      class="gallery-thumb relative aspect-video rounded-md overflow-hidden bg-surface-muted group focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent-primary"
      data-gallery-index={i}
      aria-label={`View ${itemLabel(item)}`}
    >
      {(item.type === 'image' || item.type === 'youtube') && (
        <img
          src={thumbSrc(item)}
          alt={itemLabel(item)}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      )}
      {item.type === 'vimeo' && (
        <div class="w-full h-full flex items-center justify-center bg-surface-muted">
          <span class="text-xs text-text-secondary px-2 text-center line-clamp-2">{item.title}</span>
        </div>
      )}
      {(item.type === 'youtube' || item.type === 'vimeo') && (
        <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/50 transition-colors">
          <svg class="w-8 h-8 text-white drop-shadow" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 5v14l11-7z" />
          </svg>
        </div>
      )}
      {item.type === 'image' && (
        <div class="absolute inset-0 flex items-center justify-center bg-transparent group-hover:bg-black/20 transition-colors">
          <svg class="w-6 h-6 text-white opacity-0 group-hover:opacity-100 drop-shadow transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
          </svg>
        </div>
      )}
    </button>
  ))}
</div>

<!-- ─── Lightbox ───────────────────────────────────────────────────── -->
<!--
  Layout: the overlay is a flex column that fills fixed inset-0.
  Padding is set in CSS using max(base, env(safe-area-inset-*)) so the
  close button and strip are always clear of the notch / home indicator.
  The card uses flex-1 min-h-0 to fill available space after padding —
  no explicit height calc needed.
  The media row uses flex-1 min-h-0 for the remaining height after chrome.
-->
<div
  id="gallery-lightbox"
  class="hidden fixed inset-0 z-[60] overflow-hidden flex flex-col"
  role="dialog"
  aria-modal="true"
  aria-label="Gallery viewer"
>
  <!-- Content card: mx-auto for horizontal centering; flex-1 min-h-0 fills overlay height -->
  <div class="gl-card flex flex-col w-full max-w-5xl mx-auto flex-1 min-h-0 gap-1.5 sm:gap-2">

    <!-- Top bar: counter + close (fixed height) -->
    <div class="flex items-center justify-between shrink-0">
      <span id="gallery-counter" class="gl-meta text-sm tabular-nums select-none"></span>
      <button id="gallery-close" class="gl-btn" aria-label="Close gallery">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Media row: grows to fill remaining space -->
    <div class="gl-media-row flex items-center gap-1 sm:gap-2">
      <button id="gallery-prev" class="gl-btn shrink-0" aria-label="Previous">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <div id="gallery-content" class="gl-content flex items-center justify-center overflow-hidden">
        <!-- Injected: <img> or <div class="gl-video"><iframe></div> -->
      </div>

      <button id="gallery-next" class="gl-btn shrink-0" aria-label="Next">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    <!-- Caption (fixed height) -->
    <p id="gallery-caption" class="gl-meta text-center text-sm shrink-0 min-h-[1.25rem] px-8 select-none"></p>

    <!--
      Thumbnail strip — hidden in phone landscape (orientation:landscape + short
      viewport) where vertical space is too limited to use them comfortably.
      The counter (e.g. "2 / 5") still communicates position.
    -->
    <div class="gl-strip-container overflow-x-auto shrink-0">
      <div class="flex gap-1.5 w-max">
        {items.map((item, i) => (
          <button
            class="gl-strip-thumb shrink-0 w-14 h-9 sm:w-16 sm:h-10 rounded overflow-hidden relative focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent-primary"
            data-strip-index={i}
            aria-label={`Go to item ${i + 1}`}
            tabindex="-1"
          >
            {(item.type === 'image' || item.type === 'youtube') && (
              <img src={thumbSrc(item)} alt="" class="w-full h-full object-cover" loading="lazy" />
            )}
            {item.type === 'vimeo' && (
              <div class="w-full h-full bg-surface-muted flex items-center justify-center">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              </div>
            )}
          </button>
        ))}
      </div>
    </div>

  </div><!-- /gl-card -->
</div><!-- /gallery-lightbox -->

<!--
  is:global so that :root[data-theme="dark"] selectors are not broken
  by Astro's scoped CSS attribute transformation.
-->
<style is:global>
  /*
   * ── Overlay ──
   * Padding uses max(base, env(safe-area-inset-*)) so the close button
   * and strip are always outside the notch / home indicator safe zones.
   * overscroll-behavior:none prevents iOS from scrolling the page when
   * the overlay is touched (body.style.overflow:hidden is unreliable on iOS).
   */
  #gallery-lightbox {
    background-color: rgba(248, 248, 248, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    overscroll-behavior: none;
    /*
     * Explicit height so flex-1 on .gl-card has a definite parent size
     * to grow into. position:fixed inset:0 already constrains to viewport,
     * but some mobile Chrome builds don't treat that as a definite flex
     * container height without an explicit value.
     */
    height: 100vh;
    height: 100dvh;
    padding:
      max(0.75rem, env(safe-area-inset-top))
      max(0.75rem, env(safe-area-inset-right))
      max(0.75rem, env(safe-area-inset-bottom))
      max(0.75rem, env(safe-area-inset-left));
  }
  @media (min-width: 640px) {
    #gallery-lightbox {
      padding:
        max(1rem, env(safe-area-inset-top))
        max(1rem, env(safe-area-inset-right))
        max(1rem, env(safe-area-inset-bottom))
        max(1rem, env(safe-area-inset-left));
    }
  }
  :root[data-theme="dark"] #gallery-lightbox {
    background-color: rgba(10, 10, 10, 0.97);
  }

  /*
   * ── Card: fills available overlay height after padding ──
   * flex-1 min-h-0 lets the card grow to fill exactly the space the
   * overlay provides (inset-0 minus CSS padding). No explicit height
   * calc needed — padding changes propagate automatically.
   */
  /* (flex-1 min-h-0 is in the HTML class list; no extra CSS needed) */

  /* ── Media row: grows to fill all remaining card height ── */
  .gl-media-row {
    flex: 1;
    min-height: 0;
  }

  /*
   * ── Content area: fills the media row height ──
   * align-self:stretch overrides the parent's align-items:center so
   * .gl-content gets the full row height (= definite size). This breaks
   * the percentage-height resolution issue that height:100% has when the
   * parent uses align-items:center instead of stretch.
   */
  .gl-content {
    flex: 1;
    min-width: 0;
    align-self: stretch;
  }

  /* ── Images: fit within the content area ── */
  #gallery-content img {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 0.5rem;
    display: block;
  }

  /*
   * ── Videos: 16:9, constrained by both axes ──
   * width:100% sets natural size; max-height:100% causes the browser
   * to reduce both dimensions proportionally when height would overflow.
   */
  #gallery-content .gl-video {
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #000;
  }
  #gallery-content .gl-video iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ── Control buttons ── */
  .gl-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 0.375rem;
    flex-shrink: 0;
    cursor: pointer;
    color: var(--color-text-secondary);
    transition: color 0.15s, background-color 0.15s;
  }
  .gl-btn:hover {
    color: var(--color-text-primary);
    background-color: var(--color-surface-muted);
  }
  .gl-btn:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  /* ── Meta text (counter, caption) ── */
  .gl-meta { color: var(--color-text-secondary); }

  /* ── Strip thumbs ── */
  .gl-strip-thumb {
    opacity: 0.45;
    transition: opacity 0.15s;
  }
  .gl-strip-thumb:hover { opacity: 0.75; }
  .gl-strip-thumb.is-active {
    opacity: 1;
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  /*
   * ── Landscape phone: hide the strip ──
   * On short landscape viewports (<= 500px tall) there is not enough
   * vertical room for the strip to be comfortable. The counter ("2 / 5")
   * still communicates position; arrows still navigate.
   */
  @media (orientation: landscape) and (max-height: 500px) {
    .gl-strip-container { display: none; }
  }
</style>

<script>
  // @ts-nocheck
  const lightbox  = document.getElementById('gallery-lightbox');
  const contentEl = document.getElementById('gallery-content');
  const captionEl = document.getElementById('gallery-caption');
  const counterEl = document.getElementById('gallery-counter');
  const closeBtn  = document.getElementById('gallery-close');
  const prevBtn   = document.getElementById('gallery-prev');
  const nextBtn   = document.getElementById('gallery-next');

  if (lightbox && contentEl) {
    let items = [];
    let activeIndex = 0;
    let previouslyFocused = null;

    function loadItems(grid) {
      try { return JSON.parse(grid?.dataset?.galleryItems || '[]'); } catch { return []; }
    }

    function stopMedia() {
      contentEl.innerHTML = '';
    }

    function updateStrip(index) {
      document.querySelectorAll('.gl-strip-thumb').forEach((btn, i) => {
        btn.classList.toggle('is-active', i === index);
        btn.tabIndex = i === index ? 0 : -1;
      });

      /*
       * Scroll the strip container manually instead of using scrollIntoView.
       * scrollIntoView can trigger iOS Safari to scroll the *page*, which
       * with the fixed-positioning bug causes the lightbox to drift and the
       * close button to disappear under the sticky nav.
       */
      const activeThumb = document.querySelector(`.gl-strip-thumb[data-strip-index="${index}"]`);
      const container   = activeThumb?.closest('.gl-strip-container');
      if (activeThumb && container) {
        const target = activeThumb.offsetLeft
          - container.offsetWidth  / 2
          + activeThumb.offsetWidth / 2;
        container.scrollTo({ left: Math.max(0, target), behavior: 'smooth' });
      }
    }

    function renderContent(index) {
      stopMedia();
      const item = items[index];
      if (!item) return;

      if (item.type === 'image') {
        const img = document.createElement('img');
        img.src = item.src;
        img.alt = item.alt || '';
        contentEl.appendChild(img);
        captionEl.textContent = item.caption || '';
      } else {
        const wrapper = document.createElement('div');
        wrapper.className = 'gl-video';
        const iframe = document.createElement('iframe');;
        iframe.src = item.type === 'youtube'
          ? `https://www.youtube.com/embed/${item.id}?autoplay=1`
          : `https://player.vimeo.com/video/${item.id}?autoplay=1`;
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen';
        iframe.allowFullscreen = true;
        iframe.title = item.title || '';
        wrapper.appendChild(iframe);
        contentEl.appendChild(wrapper);
        captionEl.textContent = item.title || '';
      }

      counterEl.textContent = `${index + 1} / ${items.length}`;
      updateStrip(index);
    }

    function navigate(delta) {
      activeIndex = ((activeIndex + delta) % items.length + items.length) % items.length;
      renderContent(activeIndex);
    }

    function openLightbox(grid, index) {
      items = loadItems(grid);
      if (!items.length) return;
      previouslyFocused = document.activeElement;
      activeIndex = ((index % items.length) + items.length) % items.length;
      renderContent(activeIndex);
      lightbox.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function closeLightbox() {
      stopMedia();
      captionEl.textContent = '';
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
      previouslyFocused?.focus();
    }

    // Grid clicks
    document.querySelectorAll('.gallery-thumb').forEach(btn => {
      const grid = btn.closest('.gallery-grid');
      btn.addEventListener('click', () => openLightbox(grid, Number(btn.dataset.galleryIndex)));
    });

    // Strip clicks
    document.querySelectorAll('.gl-strip-thumb').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        activeIndex = Number(btn.dataset.stripIndex);
        renderContent(activeIndex);
      });
    });

    closeBtn?.addEventListener('click', closeLightbox);
    prevBtn?.addEventListener('click', () => navigate(-1));
    nextBtn?.addEventListener('click', () => navigate(1));

    // Click the backdrop (lightbox background, not card contents) to close
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape')     { e.preventDefault(); closeLightbox(); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); navigate(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); navigate(1); }
    });
  }
</script>
