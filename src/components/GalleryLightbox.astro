---
/**
 * GalleryLightbox
 * Compact thumbnail grid + full-screen lightbox with carousel.
 * - Theme-aware overlay (light/dark via :root[data-theme])
 * - z-[60]: above sticky nav (z-50)
 * - Media fills full width; prev/next arrows flank the thumbnail strip
 * - Safe-area-inset padding for notch / home-indicator devices
 * - Landscape phone: strip hidden, arrows centred below media
 * - Keyboard: Escape, ArrowLeft, ArrowRight
 * - Accessible: aria-modal, aria-label, focus management
 */
import type { GalleryItem } from '../lib/events';

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;

function thumbSrc(item: GalleryItem): string {
  if (item.type === 'youtube') return `https://img.youtube.com/vi/${item.id}/mqdefault.jpg`;
  if (item.type === 'image') return item.src;
  return '';
}

function itemLabel(item: GalleryItem): string {
  if (item.type === 'image') return item.alt;
  return item.title;
}

const itemsJson = JSON.stringify(items.map(item => {
  if (item.type === 'image') return { type: 'image', src: item.src, alt: item.alt ?? '', caption: item.caption ?? '' };
  if (item.type === 'youtube') return { type: 'youtube', id: item.id, title: item.title };
  return { type: 'vimeo', id: item.id, title: item.title };
}));
---

<!-- ─── Thumbnail grid ─────────────────────────────────────────────── -->
<div
  class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2 gallery-grid"
  data-gallery-items={itemsJson}
>
  {items.map((item, i) => (
    <button
      class="gallery-thumb relative aspect-video rounded-md overflow-hidden bg-surface-muted group focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent-primary"
      data-gallery-index={i}
      aria-label={`View ${itemLabel(item)}`}
    >
      {(item.type === 'image' || item.type === 'youtube') && (
        <img
          src={thumbSrc(item)}
          alt={itemLabel(item)}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      )}
      {item.type === 'vimeo' && (
        <div class="w-full h-full flex items-center justify-center bg-surface-muted">
          <span class="text-xs text-text-secondary px-2 text-center line-clamp-2">{item.title}</span>
        </div>
      )}
      {(item.type === 'youtube' || item.type === 'vimeo') && (
        <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/50 transition-colors">
          <svg class="w-8 h-8 text-white drop-shadow" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 5v14l11-7z" />
          </svg>
        </div>
      )}
      {item.type === 'image' && (
        <div class="absolute inset-0 flex items-center justify-center bg-transparent group-hover:bg-black/20 transition-colors">
          <svg class="w-6 h-6 text-white opacity-0 group-hover:opacity-100 drop-shadow transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
          </svg>
        </div>
      )}
    </button>
  ))}
</div>

<!-- ─── Lightbox ───────────────────────────────────────────────────── -->
<!--
  Layout (all screen sizes):

    ┌─────────────────────────────┐
    │ counter              close  │  ← top bar (shrink-0)
    ├─────────────────────────────┤
    │                             │
    │       media  (flex-1)       │  ← full width, grows to fill
    │                             │
    ├─────────────────────────────┤
    │         caption             │  ← shrink-0
    ├─────────────────────────────┤
    │ ←   [strip thumbnails]  →  │  ← shrink-0 nav row
    └─────────────────────────────┘

  On phone landscape (max-height ≤ 500px): strip hidden, arrows centred.

  .gl-card uses position:absolute inset:0 so its dimensions come directly
  from the fixed overlay's concrete pixel size — no percentage chains, no
  flex-1-needs-a-definite-parent issues, works on every mobile browser.
-->
<div
  id="gallery-lightbox"
  class="hidden fixed inset-0 z-[200] overflow-hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Gallery viewer"
>
  <div class="gl-card">

    <!-- Top bar: counter + close -->
    <div class="flex items-center justify-between shrink-0">
      <span id="gallery-counter" class="gl-meta text-sm tabular-nums select-none"></span>
      <button id="gallery-close" class="gl-btn" aria-label="Close gallery">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Media: full width, grows to fill remaining height -->
    <div id="gallery-content" class="gl-content">
      <!-- Injected by JS: <img> or <div class="gl-video"><iframe></div> -->
    </div>

    <!-- Caption -->
    <p id="gallery-caption" class="gl-meta text-center text-sm shrink-0 min-h-[1.25rem] px-2 select-none"></p>

    <!-- Nav row: prev arrow · thumbnail strip · next arrow -->
    <div class="gl-nav-row flex items-center gap-1 sm:gap-2 shrink-0">
      <button id="gallery-prev" class="gl-btn shrink-0" aria-label="Previous">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <div class="gl-strip-container flex-1 overflow-x-auto">
        <div class="flex gap-1.5 w-max mx-auto">
          {items.map((item, i) => (
            <button
              class="gl-strip-thumb shrink-0 w-14 h-9 sm:w-16 sm:h-10 rounded overflow-hidden relative focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent-primary"
              data-strip-index={i}
              aria-label={`Go to item ${i + 1}`}
              tabindex="-1"
            >
              {(item.type === 'image' || item.type === 'youtube') && (
                <img src={thumbSrc(item)} alt="" class="w-full h-full object-cover" loading="lazy" />
              )}
              {item.type === 'vimeo' && (
                <div class="w-full h-full bg-surface-muted flex items-center justify-center">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                </div>
              )}
            </button>
          ))}
        </div>
      </div>

      <button id="gallery-next" class="gl-btn shrink-0" aria-label="Next">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

  </div><!-- /gl-card -->
</div><!-- /gallery-lightbox -->

<style is:global>
  /* ── Overlay: full-screen fixed backdrop ── */
  #gallery-lightbox {
    background-color: rgba(248, 248, 248, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    overscroll-behavior: none;
  }
  :root[data-theme="dark"] #gallery-lightbox {
    background-color: rgba(10, 10, 10, 0.97);
  }

  /*
   * ── Card: position:absolute inset:0 gives it concrete pixel dimensions ──
   * This is the most reliable cross-browser approach. A child of a fixed
   * element with position:absolute inset:0 always fills the parent exactly —
   * no flex-1 percentage-resolution ambiguity, no dvh support needed.
   * max-width + margin:auto centres it on wide screens.
   * box-sizing:border-box keeps the safe-area padding inside the card.
   */
  .gl-card {
    position: absolute;
    inset: 0;
    max-width: 64rem; /* max-w-5xl */
    margin: 0 auto;
    box-sizing: border-box;
    padding:
      max(0.75rem, env(safe-area-inset-top))
      max(0.75rem, env(safe-area-inset-right))
      max(0.75rem, env(safe-area-inset-bottom))
      max(0.75rem, env(safe-area-inset-left));
    display: flex;
    flex-direction: column;
    gap: 0.375rem; /* gap-1.5 */
  }
  @media (min-width: 640px) {
    .gl-card {
      gap: 0.5rem; /* gap-2 */
      padding:
        max(1rem, env(safe-area-inset-top))
        max(1rem, env(safe-area-inset-right))
        max(1rem, env(safe-area-inset-bottom))
        max(1rem, env(safe-area-inset-left));
    }
  }

  /*
   * ── Media area: grows to fill all remaining card height ──
   * flex:1 min-height:0 works reliably here because .gl-card has a
   * concrete pixel height (from position:absolute inset:0), so the
   * flex algorithm has a definite size to distribute.
   * All flex/alignment props are in CSS to prevent Tailwind class
   * purging or ordering issues from breaking the layout.
   */
  .gl-content {
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Images: fit within the content area without cropping ── */
  #gallery-content img {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 0.5rem;
    display: block;
  }

  /*
   * ── Videos: 16:9, constrained by both axes ──
   * width:100% fills the content width. max-height:100% makes the browser
   * shrink both dimensions proportionally when the natural height would exceed
   * the available content area height.
   */
  #gallery-content .gl-video {
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #000;
  }
  #gallery-content .gl-video iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ── Control buttons ── */
  .gl-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 0.375rem;
    flex-shrink: 0;
    cursor: pointer;
    color: var(--color-text-secondary);
    transition: color 0.15s, background-color 0.15s;
  }
  .gl-btn:hover {
    color: var(--color-text-primary);
    background-color: var(--color-surface-muted);
  }
  .gl-btn:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  /* ── Meta text (counter, caption) ── */
  .gl-meta { color: var(--color-text-secondary); }

  /* ── Strip thumbs ── */
  .gl-strip-thumb {
    opacity: 0.45;
    transition: opacity 0.15s;
  }
  .gl-strip-thumb:hover { opacity: 0.75; }
  .gl-strip-thumb.is-active {
    opacity: 1;
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  /*
   * ── Landscape phone: hide the strip, centre the arrows ──
   * On short landscape viewports (≤ 500px) there isn't enough vertical room
   * for thumbnails. The "2 / 5" counter still shows position.
   */
  @media (orientation: landscape) and (max-height: 500px) {
    .gl-strip-container { display: none; }
    .gl-nav-row { justify-content: center; gap: 2rem; }
  }
</style>

<script>
  // @ts-nocheck
  const lightbox  = document.getElementById('gallery-lightbox');
  const contentEl = document.getElementById('gallery-content');
  const captionEl = document.getElementById('gallery-caption');
  const counterEl = document.getElementById('gallery-counter');
  const closeBtn  = document.getElementById('gallery-close');
  const prevBtn   = document.getElementById('gallery-prev');
  const nextBtn   = document.getElementById('gallery-next');

  if (lightbox && contentEl) {
    let items = [];
    let activeIndex = 0;
    let previouslyFocused = null;

    function loadItems(grid) {
      try { return JSON.parse(grid?.dataset?.galleryItems || '[]'); } catch { return []; }
    }

    function stopMedia() {
      contentEl.innerHTML = '';
    }

    function updateStrip(index) {
      document.querySelectorAll('.gl-strip-thumb').forEach((btn, i) => {
        btn.classList.toggle('is-active', i === index);
        btn.tabIndex = i === index ? 0 : -1;
      });

      /*
       * Scroll the strip container manually — avoids scrollIntoView() which
       * can trigger Android Chrome to toggle the address bar, changing the
       * viewport height mid-navigation and causing layout drift.
       */
      const activeThumb = document.querySelector(`.gl-strip-thumb[data-strip-index="${index}"]`);
      const container   = activeThumb?.closest('.gl-strip-container');
      if (activeThumb && container) {
        const target = activeThumb.offsetLeft
          - container.offsetWidth  / 2
          + activeThumb.offsetWidth / 2;
        container.scrollTo({ left: Math.max(0, target), behavior: 'smooth' });
      }
    }

    function renderContent(index) {
      stopMedia();
      const item = items[index];
      if (!item) return;

      if (item.type === 'image') {
        const img = document.createElement('img');
        img.src = item.src;
        img.alt = item.alt || '';
        contentEl.appendChild(img);
        captionEl.textContent = item.caption || '';
      } else {
        const wrapper = document.createElement('div');
        wrapper.className = 'gl-video';
        const iframe = document.createElement('iframe');
        iframe.src = item.type === 'youtube'
          ? `https://www.youtube.com/embed/${item.id}?autoplay=1`
          : `https://player.vimeo.com/video/${item.id}?autoplay=1`;
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen';
        iframe.allowFullscreen = true;
        iframe.title = item.title || '';
        wrapper.appendChild(iframe);
        contentEl.appendChild(wrapper);
        captionEl.textContent = item.title || '';
      }

      counterEl.textContent = `${index + 1} / ${items.length}`;
      updateStrip(index);
    }

    function navigate(delta) {
      activeIndex = ((activeIndex + delta) % items.length + items.length) % items.length;
      renderContent(activeIndex);
    }

    function openLightbox(grid, index) {
      items = loadItems(grid);
      if (!items.length) return;
      previouslyFocused = document.activeElement;
      activeIndex = ((index % items.length) + items.length) % items.length;
      renderContent(activeIndex);
      lightbox.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function closeLightbox() {
      stopMedia();
      captionEl.textContent = '';
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
      previouslyFocused?.focus();
    }

    // Grid clicks
    document.querySelectorAll('.gallery-thumb').forEach(btn => {
      const grid = btn.closest('.gallery-grid');
      btn.addEventListener('click', () => openLightbox(grid, Number(btn.dataset.galleryIndex)));
    });

    // Strip clicks
    document.querySelectorAll('.gl-strip-thumb').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        activeIndex = Number(btn.dataset.stripIndex);
        renderContent(activeIndex);
      });
    });

    closeBtn?.addEventListener('click', closeLightbox);
    prevBtn?.addEventListener('click', () => navigate(-1));
    nextBtn?.addEventListener('click', () => navigate(1));

    // Click the backdrop (lightbox background, not card) to close
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape')     { e.preventDefault(); closeLightbox(); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); navigate(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); navigate(1); }
    });
  }
</script>
