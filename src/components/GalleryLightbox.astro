---
/**
 * GalleryLightbox
 * Compact thumbnail grid + full-screen lightbox with carousel.
 * - Theme-aware overlay (light/dark)
 * - z-[60] sits above the sticky nav (z-50)
 * - Content-centred layout: thumbnails directly below the media
 * - Keyboard: Escape, ArrowLeft, ArrowRight
 * - Accessible: aria-modal, aria-label, focus management
 */
import type { GalleryItem } from '../lib/events';

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;

function thumbSrc(item: GalleryItem): string {
  if (item.type === 'youtube') return `https://img.youtube.com/vi/${item.id}/mqdefault.jpg`;
  if (item.type === 'image') return item.src;
  return '';
}

function itemLabel(item: GalleryItem): string {
  if (item.type === 'image') return item.alt;
  return item.title;
}

const itemsJson = JSON.stringify(items.map(item => {
  if (item.type === 'image') return { type: 'image', src: item.src, alt: item.alt ?? '', caption: item.caption ?? '' };
  if (item.type === 'youtube') return { type: 'youtube', id: item.id, title: item.title };
  return { type: 'vimeo', id: item.id, title: item.title };
}));
---

<!-- ─── Thumbnail grid ─────────────────────────────────────────────── -->
<div
  class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2 gallery-grid"
  data-gallery-items={itemsJson}
>
  {items.map((item, i) => (
    <button
      class="gallery-thumb relative aspect-video rounded-md overflow-hidden bg-surface-muted group focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent-primary"
      data-gallery-index={i}
      aria-label={`View ${itemLabel(item)}`}
    >
      {(item.type === 'image' || item.type === 'youtube') && (
        <img
          src={thumbSrc(item)}
          alt={itemLabel(item)}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      )}
      {item.type === 'vimeo' && (
        <div class="w-full h-full flex items-center justify-center bg-surface-muted">
          <span class="text-xs text-text-secondary px-2 text-center line-clamp-2">{item.title}</span>
        </div>
      )}
      {(item.type === 'youtube' || item.type === 'vimeo') && (
        <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/50 transition-colors">
          <svg class="w-8 h-8 text-white drop-shadow" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 5v14l11-7z" />
          </svg>
        </div>
      )}
      {item.type === 'image' && (
        <div class="absolute inset-0 flex items-center justify-center bg-transparent group-hover:bg-black/20 transition-colors">
          <svg class="w-6 h-6 text-white opacity-0 group-hover:opacity-100 drop-shadow transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
          </svg>
        </div>
      )}
    </button>
  ))}
</div>

<!-- ─── Lightbox overlay ───────────────────────────────────────────── -->
<!--
  z-[60] is above the sticky nav (z-50) but below the skip-nav link (z-[100]).
  Theme-aware background is set in the <style> block below.
-->
<div
  id="gallery-lightbox"
  class="gallery-lightbox hidden fixed inset-0 z-[60] flex items-center justify-center overflow-y-auto"
  role="dialog"
  aria-modal="true"
  aria-label="Gallery viewer"
>
  <!-- Inner card — constrained width, stacked vertically, centred -->
  <div
    class="gallery-lightbox-inner flex flex-col w-full max-w-5xl mx-auto px-3 py-4 sm:px-6 sm:py-6 gap-2 sm:gap-3"
    role="document"
  >

    <!-- Top bar: item counter (left) + close button (right) -->
    <div class="flex items-center justify-between">
      <span id="gallery-counter" class="gallery-meta text-sm tabular-nums select-none"></span>
      <button
        id="gallery-close"
        class="gallery-ctrl-btn"
        aria-label="Close gallery"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Media + prev/next arrows -->
    <div class="flex items-center gap-1 sm:gap-2">
      <button id="gallery-prev" class="gallery-ctrl-btn shrink-0" aria-label="Previous">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <div id="gallery-content" class="flex-1 flex items-center justify-center min-w-0">
        <!-- Injected by JS: <img> or <div class="video-wrapper"><iframe></div> -->
      </div>

      <button id="gallery-next" class="gallery-ctrl-btn shrink-0" aria-label="Next">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>

    <!-- Caption / title -->
    <p id="gallery-caption" class="gallery-meta text-center text-sm min-h-[1.25rem] px-8 select-none"></p>

    <!-- Thumbnail strip -->
    <div class="overflow-x-auto">
      <div id="gallery-strip-inner" class="flex gap-1.5 w-max mx-auto">
        {items.map((item, i) => (
          <button
            class="gallery-strip-thumb shrink-0 w-14 h-9 sm:w-16 sm:h-10 rounded overflow-hidden relative focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent-primary"
            data-strip-index={i}
            aria-label={`Go to item ${i + 1}`}
            tabindex="-1"
          >
            {(item.type === 'image' || item.type === 'youtube') && (
              <img src={thumbSrc(item)} alt="" class="w-full h-full object-cover" loading="lazy" />
            )}
            {item.type === 'vimeo' && (
              <div class="w-full h-full bg-surface-muted flex items-center justify-center">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              </div>
            )}
          </button>
        ))}
      </div>
    </div>

  </div><!-- /lightbox-inner -->
</div><!-- /lightbox -->

<style>
  /* ── Theme-aware overlay ── */
  .gallery-lightbox {
    background-color: rgba(250, 250, 250, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  [data-theme="dark"] .gallery-lightbox {
    background-color: rgba(8, 8, 8, 0.97);
  }

  /* ── Control buttons (close / prev / next) ── */
  .gallery-ctrl-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 0.375rem;
    color: var(--color-text-secondary);
    transition: color 0.15s ease, background-color 0.15s ease;
    cursor: pointer;
    flex-shrink: 0;
  }
  .gallery-ctrl-btn:hover {
    color: var(--color-text-primary);
    background-color: var(--color-surface-muted);
  }
  .gallery-ctrl-btn:focus-visible {
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  /* ── Meta text (counter, caption) ── */
  .gallery-meta {
    color: var(--color-text-secondary);
  }

  /* ── Thumbnail strip ── */
  .gallery-strip-thumb {
    opacity: 0.45;
    transition: opacity 0.15s ease;
  }
  .gallery-strip-thumb:hover {
    opacity: 0.75;
  }
  .gallery-strip-thumb.is-active {
    opacity: 1;
    outline: 2px solid var(--color-accent-primary);
    outline-offset: 2px;
  }

  /* ── Media inside lightbox ── */
  #gallery-content img {
    max-height: 52vh;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    border-radius: 0.375rem;
  }

  #gallery-content .video-wrapper {
    /* Maintain 16:9 but cap height */
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: 52vh;
    /* If width would exceed 52vh × 16/9, shrink to fit height */
    max-width: calc(52vh * (16 / 9));
    border-radius: 0.375rem;
    overflow: hidden;
    background: #000;
  }
  #gallery-content .video-wrapper iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (min-width: 640px) {
    #gallery-content img,
    #gallery-content .video-wrapper {
      max-height: 60vh;
    }
    #gallery-content .video-wrapper {
      max-width: calc(60vh * (16 / 9));
    }
  }
</style>

<script>
  // @ts-nocheck
  // GalleryLightbox — Astro deduplicates this; one instance handles the page.

  const lightbox   = document.getElementById('gallery-lightbox');
  const contentEl  = document.getElementById('gallery-content');
  const captionEl  = document.getElementById('gallery-caption');
  const counterEl  = document.getElementById('gallery-counter');
  const closeBtn   = document.getElementById('gallery-close');
  const prevBtn    = document.getElementById('gallery-prev');
  const nextBtn    = document.getElementById('gallery-next');

  if (lightbox && contentEl) {
    let items = [];
    let activeIndex = 0;
    let previouslyFocused = null;

    function loadItems(grid) {
      try { return JSON.parse(grid?.dataset?.galleryItems || '[]'); } catch { return []; }
    }

    function stopMedia() {
      contentEl.innerHTML = '';
    }

    function updateStrip(index) {
      document.querySelectorAll('.gallery-strip-thumb').forEach((btn, i) => {
        btn.classList.toggle('is-active', i === index);
        btn.tabIndex = i === index ? 0 : -1;
      });
      const active = document.querySelector(`.gallery-strip-thumb[data-strip-index="${index}"]`);
      active?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    function renderContent(index) {
      stopMedia();
      const item = items[index];
      if (!item) return;

      if (item.type === 'image') {
        const img = document.createElement('img');
        img.src = item.src;
        img.alt = item.alt || '';
        contentEl.appendChild(img);
        captionEl.textContent = item.caption || '';
      } else {
        const wrapper = document.createElement('div');
        wrapper.className = 'video-wrapper';
        const iframe = document.createElement('iframe');
        iframe.src = item.type === 'youtube'
          ? `https://www.youtube.com/embed/${item.id}?autoplay=1`
          : `https://player.vimeo.com/video/${item.id}?autoplay=1`;
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen';
        iframe.allowFullscreen = true;
        iframe.title = item.title || '';
        wrapper.appendChild(iframe);
        contentEl.appendChild(wrapper);
        captionEl.textContent = item.title || '';
      }

      counterEl.textContent = `${index + 1} / ${items.length}`;
      updateStrip(index);
    }

    function navigate(delta) {
      activeIndex = ((activeIndex + delta) % items.length + items.length) % items.length;
      renderContent(activeIndex);
    }

    function openLightbox(grid, index) {
      items = loadItems(grid);
      if (!items.length) return;
      previouslyFocused = document.activeElement;
      activeIndex = ((index % items.length) + items.length) % items.length;
      renderContent(activeIndex);
      lightbox.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function closeLightbox() {
      stopMedia();
      captionEl.textContent = '';
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
      previouslyFocused?.focus();
    }

    // Grid thumbnail clicks
    document.querySelectorAll('.gallery-thumb').forEach(btn => {
      const grid = btn.closest('.gallery-grid');
      btn.addEventListener('click', () => openLightbox(grid, Number(btn.dataset.galleryIndex)));
    });

    // Strip thumbnail clicks
    document.querySelectorAll('.gallery-strip-thumb').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        activeIndex = Number(btn.dataset.stripIndex);
        renderContent(activeIndex);
      });
    });

    closeBtn?.addEventListener('click', closeLightbox);
    prevBtn?.addEventListener('click', () => navigate(-1));
    nextBtn?.addEventListener('click', () => navigate(1));

    // Click backdrop to close (only when clicking the overlay itself, not inner content)
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape')      { e.preventDefault(); closeLightbox(); }
      if (e.key === 'ArrowLeft')   { e.preventDefault(); navigate(-1); }
      if (e.key === 'ArrowRight')  { e.preventDefault(); navigate(1); }
    });
  }
</script>
