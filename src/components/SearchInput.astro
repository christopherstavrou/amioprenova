---
/**
 * SearchInput — search field + results dropdown for paginated list pages.
 * Wired by list-search.ts via fixed IDs: #search-input and #search-results.
 * One instance per page only — the fixed IDs are safe because list pages
 * never render more than one search field.
 */
interface Props {
  labels?: {
    placeholder?: string;
  };
}

const { labels = {} } = Astro.props;
const L = {
  placeholder: labels.placeholder ?? 'Search...',
};
---

<div class="relative w-full md:w-64">
  <input
    type="search"
    id="search-input"
    placeholder={L.placeholder}
    class="w-full px-4 py-2 bg-surface border border-border rounded-lg focus:outline-none focus:border-accent-primary text-text-primary placeholder:text-text-secondary transition-colors"
  />
  <div
    id="search-results"
    class="hidden absolute top-full mt-2 w-full bg-surface-elevated border border-border rounded-lg shadow-lg max-h-96 overflow-y-auto z-10"
  ></div>
</div>
