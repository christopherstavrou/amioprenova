---
import SharePopover from './SharePopover.astro';

interface ActionItem {
  href: string;
  label: string;
  icon: 'ticket' | 'map' | 'facebook';
}

interface Props {
  items: ActionItem[];
  shareUrl: string;
  shareTitle: string;
  class?: string;
  labels?: {
    menu?: string;
    share?: string;
    copyLink?: string;
    copied?: string;
    facebook?: string;
    twitter?: string;
  };
}

const { items, shareUrl, shareTitle, class: className = '', labels = {} } = Astro.props;
const L = {
  menu: labels.menu ?? 'Show actions',
  share: labels.share ?? 'Share',
  copyLink: labels.copyLink ?? 'Copy link',
  copied: labels.copied ?? 'Copied!',
  facebook: labels.facebook ?? 'Facebook',
  twitter: labels.twitter ?? 'Twitter / X',
};
---

<div class={`show-actions-menu relative inline-block ${className}`}>
  <button
    type="button"
    class="show-actions-trigger inline-flex h-10 w-10 items-center justify-center rounded-md border border-border/60 bg-[rgba(247,244,240,0.82)] text-accent-primary shadow-sm backdrop-blur-md hover:border-accent-primary hover:bg-[rgba(247,244,240,0.92)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-primary dark:bg-[rgba(13,12,11,0.82)] dark:hover:bg-[rgba(13,12,11,0.92)]"
    aria-label={L.menu}
    aria-expanded="false"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 5h.01M12 12h.01M12 19h.01" />
    </svg>
  </button>

  <div class="show-actions-panel hidden absolute right-0 top-full z-30 mt-2 w-56 rounded-lg border border-border bg-surface-elevated p-2 shadow-lg">
    {items.map((item) => (
      <a
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5 rounded-md px-3 py-2 text-sm text-text-primary hover:bg-surface-muted transition-colors"
      >
        {item.icon === 'ticket' && (
          <svg class="w-4 h-4 shrink-0 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
          </svg>
        )}
        {item.icon === 'map' && (
          <svg class="w-4 h-4 shrink-0 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        )}
        {item.icon === 'facebook' && (
          <svg class="w-4 h-4 shrink-0 text-accent-primary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13.135 22v-8.03h2.695l.404-3.13h-3.1V8.84c0-.906.252-1.523 1.551-1.523H16.25V4.52a21.2 21.2 0 00-2.283-.117c-2.258 0-3.804 1.379-3.804 3.91v2.527H7.61v3.13h2.553V22h2.972z" />
          </svg>
        )}
        <span>{item.label}</span>
      </a>
    ))}

    <div class="my-1 border-t border-border"></div>

    <SharePopover
      url={shareUrl}
      title={shareTitle}
      variant="menu-item"
      labels={{ share: L.share, copyLink: L.copyLink, copied: L.copied, facebook: L.facebook, twitter: L.twitter }}
      class="w-full"
    />
  </div>
</div>

<script>
  // @ts-nocheck
  document.querySelectorAll('.show-actions-menu').forEach((root, i) => {
    const trigger = root.querySelector('.show-actions-trigger');
    const panel = root.querySelector('.show-actions-panel');
    if (!trigger || !panel) return;
    const panelId = `show-actions-panel-${i}`;
    panel.id = panelId;
    trigger.setAttribute('aria-controls', panelId);
  });

  function closeAllMenus() {
    document.querySelectorAll('.show-actions-panel').forEach((panel) => panel.classList.add('hidden'));
    document.querySelectorAll('.show-actions-trigger').forEach((trigger) => trigger.setAttribute('aria-expanded', 'false'));
  }

  document.addEventListener('click', (event) => {
    const trigger = event.target.closest('.show-actions-trigger');
    const menuRoot = event.target.closest('.show-actions-menu');

    if (trigger) {
      event.stopPropagation();
      const panel = trigger.parentElement.querySelector('.show-actions-panel');
      if (!panel) return;
      const isHidden = panel.classList.contains('hidden');
      closeAllMenus();
      if (isHidden) {
        panel.classList.remove('hidden');
        trigger.setAttribute('aria-expanded', 'true');
      }
      return;
    }

    if (!menuRoot) closeAllMenus();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeAllMenus();
  });
</script>
