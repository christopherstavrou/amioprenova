---
/**
 * Button component
 * Reusable button with primary, secondary, and ghost variants
 * Based on DESIGN.md specifications
 */

export interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  target?: string;
  rel?: string;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  class: className = '',
  target,
  rel
} = Astro.props;

// Base classes for all buttons
const baseClasses = 'inline-flex items-center justify-center px-6 py-3 rounded-md font-medium transition-all duration-fast focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-primary disabled:opacity-50 disabled:cursor-not-allowed';

// Variant-specific classes
const variantClasses = {
  primary: 'bg-accent-primary text-text-inverse hover:bg-accent-primary-hover hover:text-text-inverse active:text-text-inverse shadow-sm hover:shadow-md',
  secondary: 'border-2 border-accent-primary text-accent-primary bg-transparent hover:bg-accent-primary hover:text-text-inverse',
  ghost: 'text-accent-primary hover:bg-surface-muted'
};

const classes = `${baseClasses} ${variantClasses[variant]} ${className}`;
---

{href ? (
  <a
    href={href}
    class={classes}
    target={target}
    rel={rel}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    class={classes}
  >
    <slot />
  </button>
)}
