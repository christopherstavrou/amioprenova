---
/**
 * SharePopover
 * On mobile/supported browsers: triggers the native Web Share sheet.
 * On desktop fallback: shows an inline popover with copy-link + social share.
 */
interface Props {
  url: string;
  title: string;
  class?: string;
  variant?: 'icon' | 'button' | 'menu-item';
  labels?: {
    share?: string;
    copyLink?: string;
    copied?: string;
    facebook?: string;
    twitter?: string;
  };
}

const { url, title, class: className = '', variant = 'icon', labels = {} } = Astro.props;
const L = {
  share:    labels.share    ?? 'Share',
  copyLink: labels.copyLink ?? 'Copy link',
  copied:   labels.copied   ?? 'Copied!',
  facebook: labels.facebook ?? 'Facebook',
  twitter:  labels.twitter  ?? 'Twitter / X',
};
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const triggerClasses = {
  icon: 'inline-flex items-center justify-center rounded-md border-2 border-accent-primary px-3 py-3 text-accent-primary hover:bg-accent-primary hover:text-text-inverse',
  button: 'inline-flex items-center justify-center gap-2.5 rounded-md border-2 border-accent-primary px-4 py-2.5 text-sm font-medium text-accent-primary hover:bg-accent-primary hover:text-text-inverse',
  'menu-item': 'flex w-full items-center gap-2.5 rounded-md px-3 py-2 text-left text-sm text-text-primary hover:bg-surface-muted',
}[variant];
---

<div class={`share-popover relative inline-block ${className}`}>
  <button
    type="button"
    class={`share-trigger ${triggerClasses} transition-all duration-fast focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-primary`}
    aria-label={L.share}
    aria-expanded="false"
    data-share-url={url}
    data-share-title={title}
  >
    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8.625 10.5a2.625 2.625 0 110-5.25 2.625 2.625 0 010 5.25zm6.75 8.25a2.625 2.625 0 110-5.25 2.625 2.625 0 010 5.25zM8.625 18.75a2.625 2.625 0 110-5.25 2.625 2.625 0 010 5.25z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M10.9 9.6l2.2 1.3m-2.2 2.2l2.2-1.3" />
    </svg>
    {variant !== 'icon' && <span>{L.share}</span>}
  </button>

  <div class="share-panel hidden absolute bottom-full right-0 mb-2 w-52 bg-surface-elevated border border-border rounded-lg shadow-lg z-30 p-2">
    <button
      type="button"
      class="copy-link-btn w-full flex items-center gap-2 px-3 py-2 text-sm text-text-primary rounded hover:bg-surface-muted transition-colors text-left"
      data-copy-url={url}
      data-copy-label={L.copyLink}
      data-copied-label={L.copied}
    >
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
      <span>{L.copyLink}</span>
    </button>
    <div class="border-t border-border my-1"></div>
    <a
      href={facebookUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 px-3 py-2 text-sm text-text-primary rounded hover:bg-surface-muted transition-colors"
    >
      <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M13.135 22v-8.03h2.695l.404-3.13h-3.1V8.84c0-.906.252-1.523 1.551-1.523H16.25V4.52a21.2 21.2 0 00-2.283-.117c-2.258 0-3.804 1.379-3.804 3.91v2.527H7.61v3.13h2.553V22h2.972z" />
      </svg>
      {L.facebook}
    </a>
    <a
      href={twitterUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 px-3 py-2 text-sm text-text-primary rounded hover:bg-surface-muted transition-colors"
    >
      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      {L.twitter}
    </a>
  </div>
</div>

<script>
  // @ts-nocheck
  // Deduplicated by Astro — runs once per page even with multiple SharePopover instances.

  // Assign unique IDs to each panel and wire aria-controls on the trigger.
  document.querySelectorAll('.share-popover').forEach((root, i) => {
    const trigger = root.querySelector('.share-trigger');
    const panel   = root.querySelector('.share-panel');
    if (!trigger || !panel) return;
    const panelId = `share-panel-${i}`;
    panel.id = panelId;
    trigger.setAttribute('aria-controls', panelId);
  });

  function openPanel(trigger) {
    const panel = trigger.parentElement.querySelector('.share-panel');
    if (!panel) return;
    const isHidden = panel.classList.contains('hidden');
    closeAllPanels();
    if (isHidden) {
      panel.classList.remove('hidden');
      trigger.setAttribute('aria-expanded', 'true');
    }
  }

  function closeAllPanels() {
    document.querySelectorAll('.share-panel').forEach(p => p.classList.add('hidden'));
    document.querySelectorAll('.share-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));
  }

  document.addEventListener('click', async (e) => {
    const trigger = e.target.closest('.share-trigger');
    const copyBtn = e.target.closest('.copy-link-btn');

    if (trigger) {
      e.stopPropagation();
      const url = trigger.dataset.shareUrl;
      const shareTitle = trigger.dataset.shareTitle;

      if (navigator.share) {
        try {
          await navigator.share({ title: shareTitle, url });
        } catch (err) {
          if (err.name !== 'AbortError') openPanel(trigger);
        }
        return;
      }
      openPanel(trigger);

    } else if (copyBtn) {
      e.stopPropagation();
      const url = copyBtn.dataset.copyUrl;
      const span = copyBtn.querySelector('span');
      try {
        await navigator.clipboard.writeText(url);
        if (span) {
          span.textContent = copyBtn.dataset.copiedLabel ?? 'Copied!';
          setTimeout(() => { span.textContent = copyBtn.dataset.copyLabel ?? 'Copy link'; }, 2000);
        }
      } catch {
        // clipboard API unavailable
      }

    } else if (!e.target.closest('.share-panel')) {
      closeAllPanels();
    }
  });
</script>
